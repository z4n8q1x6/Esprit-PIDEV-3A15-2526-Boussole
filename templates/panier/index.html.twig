{% extends 'front_base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block content %}
<div class="row">
    <div class="col-12 mb-4">
        <h2 class="fw-bold">Mon Panier</h2>
        <p class="text-muted">Gérez les articles de votre panier avant de passer commande.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                {% if items|length > 0 %}
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Produit</th>
                                    <th>Prix unitaire</th>
                                    <th style="width: 150px;">Quantité</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                {% if item.produit.image %}
                                                    <img src="{{ asset(item.produit.image) }}" alt="{{ item.produit.nom }}" style="width: 50px; height: 50px; object-fit: contain;" class="me-3 bg-light p-1 rounded">
                                                {% endif %}
                                                <div>
                                                    <h6 class="mb-0 fw-bold">{{ item.produit.nom }}</h6>
                                                    <small class="text-muted">Réf: {{ item.produit.reference }}</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            {% if item.produit.pourcentageReduction > 0 %}
                                                <del class="text-muted small">{{ item.produit.prixAchat|number_format(2, ',', ' ') }} DT</del><br>
                                                <span class="text-danger fw-bold">{{ item.produit.prixApresReduction|number_format(2, ',', ' ') }} DT</span>
                                                <span class="badge bg-danger ms-1">-{{ item.produit.pourcentageReduction }}%</span>
                                            {% else %}
                                                {{ item.produit.prixAchat|number_format(2, ',', ' ') }} DT
                                            {% endif %}
                                        </td>
                                        <td>
                                            <form action="{{ path('app_panier_update', {'id': item.produit.id}) }}" method="post" class="d-flex">
                                                <input type="number" name="quantity" value="{{ item.quantity }}" min="1" class="form-control form-control-sm text-center me-2" style="width: 70px;">
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Mettre à jour">
                                                    <i class="bi bi-arrow-clockwise"></i>
                                                </button>
                                            </form>
                                        </td>
                                        <td class="fw-bold text-primary">{{ (item.produit.prixApresReduction * item.quantity)|number_format(2, ',', ' ') }} DT</td>
                                        <td class="text-end">
                                            <a href="{{ path('app_panier_remove', {'id': item.produit.id}) }}" class="btn btn-sm btn-outline-danger" title="Retirer du panier">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
                        <h5 class="mt-3">Votre panier est vide</h5>
                        <p class="text-muted">Découvrez nos produits sur la marketplace.</p>
                        <a href="{{ path('app_marketplace') }}" class="btn btn-primary mt-2">Visiter la boutique</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    
    {% if items|length > 0 %}
    <div class="col-lg-4">
        <!-- Programme de Fidélité -->
        <div class="card shadow-sm border-0 bg-light mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">Programme Fidélité</h5>
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-star-fill text-warning fs-3 me-3"></i>
                    <div>
                        <p class="mb-0 text-muted small">Solde actuel</p>
                        <h4 class="mb-0 fw-bold text-dark">{{ franchise_points|default(0) }} <span class="fs-6 text-muted">pts</span></h4>
                    </div>
                </div>
                
                <form action="{{ path('app_panier_checkout') }}" method="post" id="checkout-form">
                    {% set max_points = (total * 0.5 * 10)|round(0, 'floor') %}
                    {% set usable_points = min(franchise_points|default(0), max_points) %}
                    
                    <div class="mb-2">
                        <label class="form-label small fw-bold">Utiliser des points (Max {{ usable_points }})</label>
                        <div class="input-group">
                            <input type="number" name="points_to_use" id="points-to-use" class="form-control" value="0" min="0" max="{{ usable_points }}">
                            <span class="input-group-text bg-white"><i class="bi bi-star text-warning"></i></span>
                        </div>
                        <div class="form-text text-success fw-bold mt-2" id="discount-preview">
                            Réduction : -0,00 DT
                        </div>
                    </div>
                    
                    <hr>
                    <div class="mb-2">
                        <label class="form-label small fw-bold">Code Coupon (Optionnel)</label>
                        <div class="input-group">
                            <input type="text" name="coupon_code" class="form-control text-uppercase" placeholder="Ex: ABCDEF" maxlength="6">
                            <span class="input-group-text bg-white"><i class="bi bi-ticket-detailed text-primary"></i></span>
                        </div>
                        <div class="form-text text-muted small">Remise fixe de 10 DT applicable sur le total.</div>
                    </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 bg-light">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">Résumé de la commande</h5>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Sous-total</span>
                    <span class="fw-bold" id="subtotal-display" data-value="{{ total }}">{{ total|number_format(2, ',', ' ') }} DT</span>
                </div>
                <div class="d-flex justify-content-between mb-3 text-success d-none" id="discount-row">
                    <span>Réduction (Fidélité)</span>
                    <span class="fw-bold" id="discount-amount">-0,00 DT</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-2">
                    <span class="fs-5 fw-bold">Total</span>
                    <span class="fs-5 fw-bold text-primary" id="final-total">{{ total|number_format(2, ',', ' ') }} DT</span>
                </div>
                <div class="mb-4 text-end">
                    <small class="text-muted"><i class="bi bi-gift me-1"></i>Gain : <strong class="text-warning" id="earned-points-preview">{{ (total * 10)|round(0, 'floor') }} pts</strong></small>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">Valider la commande</button>
                </form>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const pointsInput = document.getElementById('points-to-use');
    if (!pointsInput) return;

    const subtotal = parseFloat(document.getElementById('subtotal-display').getAttribute('data-value'));
    const maxPoints = parseInt(pointsInput.getAttribute('max')) || 0;
    
    const finalTotalEl = document.getElementById('final-total');
    const discountPreviewEl = document.getElementById('discount-preview');
    const discountRowEl = document.getElementById('discount-row');
    const discountAmountEl = document.getElementById('discount-amount');
    const earnedPointsEl = document.getElementById('earned-points-preview');

    function updateCalculations() {
        let points = parseInt(pointsInput.value) || 0;
        
        if (points > maxPoints) {
            points = maxPoints;
            pointsInput.value = points;
        }
        if (points < 0) {
            points = 0;
            pointsInput.value = points;
        }

        const discount = points / 10;
        const finalTotal = Math.max(0, subtotal - discount);
        const earnedPoints = Math.floor(finalTotal * 10);

        discountPreviewEl.textContent = `Réduction : -${discount.toFixed(2).replace('.', ',')} DT`;
        
        if (discount > 0) {
            discountRowEl.classList.remove('d-none');
            discountAmountEl.textContent = `-${discount.toFixed(2).replace('.', ',')} DT`;
        } else {
            discountRowEl.classList.add('d-none');
        }

        finalTotalEl.textContent = `${finalTotal.toFixed(2).replace('.', ',')} DT`;
        earnedPointsEl.textContent = `${earnedPoints} pts`;
    }

    pointsInput.addEventListener('input', updateCalculations);
});
</script>
{% endblock %}
