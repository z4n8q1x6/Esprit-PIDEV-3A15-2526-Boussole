{% extends 'front_base.html.twig' %}

{% block title %}Mes Commandes{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold">Mes Commandes</h2>
        <p class="text-muted">Consultez l'historique et le statut de vos commandes.</p>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">N° Commande</th>
                        <th class="py-3">Date</th>
                        <th class="py-3">Articles</th>
                        <th class="py-3">Total</th>
                        <th class="py-3">Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for commande in commandes %}
                        <tr>
                            <td class="ps-4 fw-bold">#CMD-{{ commande.id|default('00') }}</td>
                            <td>{{ commande.date_creation|date('d/m/Y H:i') }}</td>
                            <td>
                                <ul class="list-unstyled mb-0 small">
                                    {% for ligne in commande.ligne_commandes %}
                                        <li>{{ ligne.quantite }}x {{ ligne.produit_id.nom|default('Produit supprimé') }}</li>
                                    {% endfor %}
                                </ul>
                            </td>
                            <td class="fw-bold text-primary">
                                {{ commande.montant_total|number_format(2, ',', ' ') }} DT
                                {% if commande.pointsUtilises > 0 %}
                                    <br><small class="text-success" style="font-size: 0.75rem;"><i class="bi bi-star-fill"></i> -{{ (commande.pointsUtilises / 10)|number_format(2, ',', ' ') }} DT ({{ commande.pointsUtilises }} pts)</small>
                                {% endif %}
                                {% if commande.remiseCoupon > 0 %}
                                    <br><small class="text-success" style="font-size: 0.75rem;"><i class="bi bi-ticket-detailed"></i> Coupon {{ commande.couponCode }} : -{{ commande.remiseCoupon|number_format(2, ',', ' ') }} DT</small>
                                {% endif %}
                                {% if commande.pointsGagnes > 0 %}
                                    <br><small class="text-warning" style="font-size: 0.75rem;"><i class="bi bi-gift"></i> +{{ commande.pointsGagnes }} pts gagnés</small>
                                {% endif %}
                            </td>
                            <td>
                                {% if commande.statut == 'En attente' %}
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i>En attente</span>
                                {% elseif commande.statut == 'Validée' %}
                                    <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i>{{ commande.statut }}</span>
                                {% elseif commande.statut == 'Refusée' %}
                                    <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i>Refusée</span>
                                {% else %}
                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">{{ commande.statut }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
                                <h5 class="mt-3">Aucune commande trouvée</h5>
                                <p class="text-muted">Vous n'avez pas encore passé de commande.</p>
                                <a href="{{ path('app_marketplace') }}" class="btn btn-outline-primary mt-2">Visiter la boutique</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
