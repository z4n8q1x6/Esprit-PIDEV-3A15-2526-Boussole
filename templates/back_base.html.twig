<!-- SweetAlert2 pour Notifications Dynamiques et Script de Recherche -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    // Le système de notifications est désormais géré automatiquement par PHP Flasher (Flasher SweetAlert Bundle)

    // 2. Système de Recherche (Filtrage du menu latéral en direct)
    const searchInput = document.getElementById('back-search-input');
    const menuItems = document.querySelectorAll('#navbar-sidebar .nav-item');

    
    if (searchInput) {
        searchInput.addEventListener('keyup', function(e) {
            e.preventDefault();
            const filter = searchInput.value.toLowerCase().trim();

            menuItems.forEach(function(item) {
                // Ignore les titres de section (qui on un style différent, souvent contenant 'ms-3')
                if(item.textContent.trim() === 'Principal' || item.textContent.trim() === 'Outils') {
                    return; // ne pas cacher systématiquement les entêtes, bien qu'on puisse les gérer après
                }
                const linkLabel = item.textContent.toLowerCase();
                if(linkLabel.includes(filter)) {
                    item.style.setProperty("display", "block", "important"); // Afficher
                } else {
                    item.style.setProperty("display", "none", "important"); // Cacher
                }
            });
        });
    }
});
</script>

<!-- Gesture & Screenshot Libraries -->
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", async function() {
    const toggleBtn = document.getElementById('toggle-gesture-mode');
    if (!toggleBtn) return;

    let gestureRecognizer;
    let gestureActive = false;
    let video;
    let overlayCanvas;
    let screenStream;
    let screenVideo;
    let lastPoints = [];
    const MAX_POINTS = 60;

    function createOverlay() {
        overlayCanvas = document.createElement('canvas');
        overlayCanvas.style.position = 'fixed';
        overlayCanvas.style.top = '0';
        overlayCanvas.style.left = '0';
        overlayCanvas.style.width = '100vw';
        overlayCanvas.style.height = '100vh';
        overlayCanvas.style.zIndex = '9999';
        overlayCanvas.style.pointerEvents = 'none';
        document.body.appendChild(overlayCanvas);
        resizeOverlay();
    }

    function resizeOverlay() {
        if (!overlayCanvas) return;
        overlayCanvas.width = window.innerWidth;
        overlayCanvas.height = window.innerHeight;
    }

    window.addEventListener('resize', resizeOverlay);

    // Load MediaPipe safely using ESM Dynamic Import
    async function initMediaPipe() {
        try {
            if (gestureRecognizer) return true;
            
            const mediapipe = await import("https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.3/vision_bundle.mjs");
            const { FilesetResolver, GestureRecognizer } = mediapipe;

            const vision = await FilesetResolver.forVisionTasks("https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.3/wasm");
            gestureRecognizer = await GestureRecognizer.createFromOptions(vision, {
                baseOptions: {
                    modelAssetPath: `https://storage.googleapis.com/mediapipe-models/gesture_recognizer/gesture_recognizer/float16/1/gesture_recognizer.task`,
                    delegate: "GPU"
                },
                runningMode: "VIDEO",
                numHands: 1
            });
            return true;
        } catch (e) {
            console.error("MediaPipe Init Error:", e);
            Swal.fire({ icon: 'error', title: 'Erreur IA', text: 'Détail : ' + e.message.substring(0, 100) });
            return false;
        }
    }

    toggleBtn.addEventListener('click', async () => {
        if (!gestureRecognizer) {
            const ok = await initMediaPipe();
            if (!ok) return;
        }

        gestureActive = !gestureActive;
        if (gestureActive) {
            try {
                // Request Screen Sharing for Full Screen Capture
                screenStream = await navigator.mediaDevices.getDisplayMedia({ 
                    video: { cursor: "always" }, 
                    audio: false 
                });
                
                // Handle "Stop Sharing" button in browser
                screenStream.getVideoTracks()[0].onended = () => {
                    if (gestureActive) toggleBtn.click();
                };

                screenVideo = document.createElement('video');
                screenVideo.srcObject = screenStream;
                await screenVideo.play();

                toggleBtn.classList.remove('btn-outline-primary');
                toggleBtn.classList.add('btn-primary');
                if (!overlayCanvas) createOverlay();
                overlayCanvas.style.display = 'block';
                
                await startCamera(); // Human tracking camera
                predictLoop();
            } catch (e) {
                console.error("Screen Share Error:", e);
                gestureActive = false;
                toggleBtn.classList.replace('btn-primary', 'btn-outline-primary');
                Swal.fire({ icon: 'info', title: 'Capture annulée', text: 'Le partage d\'écran est requis pour la capture complète.' });
            }
        } else {
            toggleBtn.classList.replace('btn-primary', 'btn-outline-primary');
            if (overlayCanvas) overlayCanvas.style.display = 'none';
            stopAllStreams();
        }
    });

    async function startCamera() {
        video = document.createElement('video');
        video.style.display = 'none';
        const stream = await navigator.mediaDevices.getUserMedia({ video: true });
        video.srcObject = stream;
        await video.play();
    }

    function stopAllStreams() {
        if (video && video.srcObject) video.srcObject.getTracks().forEach(t => t.stop());
        if (screenStream) screenStream.getTracks().forEach(t => t.stop());
    }

    function predictLoop() {
        if (!gestureActive) return;
        
        const ctx = overlayCanvas.getContext('2d');
        ctx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);

        const now = performance.now();
        const results = gestureRecognizer.recognizeForVideo(video, now);

        if (results.landmarks && results.landmarks.length > 0) {
            const landmarks = results.landmarks[0];
            const indexTip = landmarks[8];
            const x = (1 - indexTip.x) * overlayCanvas.width;
            const y = indexTip.y * overlayCanvas.height;

            // Handle Detected Gestures
            if (results.gestures && results.gestures.length > 0) {
                const gesture = results.gestures[0][0];
                const label = gesture.categoryName;
                const score = gesture.score;

                if (score > 0.6) {
                    processGesture(label);
                    
                    // Draw gesture text for feedback
                    ctx.font = 'bold 24px Inter';
                    ctx.fillStyle = '#00e5ff';
                    ctx.shadowBlur = 10;
                    ctx.shadowColor = 'rgba(0,0,0,0.5)';
                    ctx.fillText(`Geste : ${label}`, x + 20, y);
                }
            }

            // Draw current finger position
            ctx.beginPath();
            ctx.arc(x, y, 10, 0, Math.PI * 2);
            ctx.fillStyle = '#00e5ff';
            ctx.shadowBlur = 15;
            ctx.shadowColor = '#00e5ff';
            ctx.fill();
        }
        
        requestAnimationFrame(predictLoop);
    }

    let lastGestureTime = 0;
    function processGesture(label) {
        const now = Date.now();
        if (now - lastGestureTime < 3000) return; // Anti-rebond global

        // ✋ MAIN LEVÉE = CAPTURE
        if (label === 'Open_Palm') {
            lastGestureTime = now;
            takeGestureScreenshot();
        } 
        
        // 👍 POUCE LEVÉ = LOGOUT
        else if (label === 'Thumb_Up') {
            lastGestureTime = now;
            Swal.fire({
                title: 'Déconnexion ?',
                text: "Vous allez être déconnecté par geste.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Oui, me déconnecter',
                timer: 4000,
                timerProgressBar: true
            }).then((result) => {
                if (result.isConfirmed || result.dismiss === Swal.DismissReason.timer) {
                    window.location.href = "{{ path('app_logout') }}";
                }
            });
        }
    }

    async function takeGestureScreenshot() {
        const flash = document.createElement('div');
        flash.style.position = 'fixed'; flash.style.top = '0'; flash.style.left = '0';
        flash.style.width = '100vw'; flash.style.height = '100vh';
        flash.style.backgroundColor = 'white'; flash.style.zIndex = '99999';
        flash.style.transition = 'opacity 0.3s ease-out';
        document.body.appendChild(flash);
        
        setTimeout(() => { flash.style.opacity = '0'; setTimeout(() => flash.remove(), 300); }, 50);

        try {
            // New Full Screen Capture logic using the Screen Stream
            const captureCanvas = document.createElement('canvas');
            captureCanvas.width = screenVideo.videoWidth;
            captureCanvas.height = screenVideo.videoHeight;
            const captureCtx = captureCanvas.getContext('2d');
            captureCtx.drawImage(screenVideo, 0, 0, captureCanvas.width, captureCanvas.height);
            
            const link = document.createElement('a');
            link.download = `Boussole_Full_Screen_${new Date().getTime()}.png`;
            link.href = captureCanvas.toDataURL('image/png');
            link.click();
            
            Swal.fire({
                icon: 'success', title: 'Écran complet capturé !',
                toast: true, position: 'top-end', showConfirmButton: false, timer: 3000
            });
        } catch (e) {
            console.error("Screenshot Error:", e);
        }
    }
});
</script>
