{% extends 'front_base.html.twig' %}

{% block title %}Boussole - Liste des Fournisseurs{% endblock %}

{% block content %}
<div class="container mt-4 pb-5">
    {# En-tête avec titre + bouton Ajouter #}
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold main-page-title mb-0">Nos Partenaires Fournisseurs</h2>
        <a href="{{ path('app_ajouter_fournisseur') }}" class="btn btn-add-modern">
            <i class="fas fa-plus-circle me-2"></i> Ajouter un fournisseur
        </a>
    </div>

    {# Widget Météo Flottant #}
    <div id="weather-widget" class="weather-widget shadow d-none d-lg-flex">
        <div class="weather-icon-container">
            <i class="fas {{ weather.icon }}"></i>
        </div>
        <div class="weather-info">
            <div class="weather-top-row">
                <span class="weather-temp">{{ weather.temp }}°C</span>
                <span class="weather-city">TUNIS</span>
            </div>
            <div class="weather-desc">{{ weather.desc }}</div>
        </div>
    </div>
    
    {# Widget IA DuckDuckGo Flottant #}
    <div id="ai-widget" class="ai-widget shadow d-none d-lg-flex" onclick="toggleAIReport()">
        <div class="ai-icon-container">
            <i class="fas fa-robot"></i>
            <span class="ai-pulse"></span>
        </div>
        <div class="ai-info">
            <div class="ai-title">BOUSSOLE IA</div>
            <div class="ai-status">Analyse en cours...</div>
        </div>
    </div>

    {# Panneau d'Insights IA (Caché par défaut) #}
    <div id="ai-report-panel" class="ai-report-panel shadow-lg">
        <div class="ai-report-header">
            <h5 class="mb-0"><i class="fas fa-microchip me-2"></i> Rapport d'Analyse IA</h5>
            <button class="btn-close btn-close-white" onclick="toggleAIReport()"></button>
        </div>
        <div class="ai-report-body">
            <div class="ai-insight-section mb-4">
                <div class="insight-label">FRANCHISE LEADER</div>
                <div class="insight-value">{{ ai_analysis.top_franchise }}</div>
                <div class="insight-sub">{{ ai_analysis.top_count }} partenaires enregistrés</div>
            </div>
            <hr class="op-2">
            <div class="ai-research-section">
                <div class="insight-label mb-3">ANALYSE EXPERTE & FINANCIÈRE</div>
                
                {% if ai_analysis.error %}
                    <div class="alert alert-warning py-2 small">
                        <i class="fas fa-exclamation-triangle me-2"></i> {{ ai_analysis.error }}
                    </div>
                {% endif %}

                {% for name, info in ai_analysis.research %}
                    <div class="research-item mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="research-title mb-0">{{ name }}</div>
                            <div class="stock-badge {{ info.stock_trend }}">
                                <i class="fas {% if info.stock_trend == 'gain' %}fa-arrow-trend-up{% elseif info.stock_trend == 'loss' %}fa-arrow-trend-down{% else %}fa-minus{% endif %}"></i>
                                {{ info.stock_status }}
                            </div>
                        </div>
                        
                        <div class="finance-badge mb-3">
                            <i class="fas fa-coins me-1"></i> CA: <strong>{{ info.revenue }}</strong>
                        </div>

                        <p class="research-text">{{ info.summary }}</p>
                        
                        <div class="research-footer">
                            <span class="source">Source: Boussole Intelligence</span>
                            <a href="{{ info.link }}" target="_blank" class="btn-more">Lire plus <i class="fas fa-external-link-alt ms-1"></i></a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {# Section News Ticker #}
    {% if news is not empty %}
    <div class="news-ticker-container mb-5 shadow-sm">
        <div class="ticker-badge">
            <span class="pulse-dot"></span>
            <span class="badge-text">BUSINESS NEWS</span>
        </div>
        <div class="ticker-body">
            <div id="news-ticker-content">
                {% for n in news %}
                    <a href="{{ n.link }}" target="_blank" class="news-item">
                        <i class="fas fa-external-link-alt me-2 small"></i>{{ n.title }}
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# Barre de recherche et de tri #}
    <div class="card mb-5 border-0 shadow-sm modern-filter-bar">
        <div class="card-body p-3">
            <form method="get" action="{{ path('app_afficher_front_fournisseur') }}" class="row g-3 align-items-center">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 py-2">
                            <i class="fas fa-search text-primary"></i>
                        </span>
                        <input type="text" name="search" class="form-control border-start-0 py-2" placeholder="Rechercher un nom ou matricule..." value="{{ currentSearch|default('') }}">
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white py-2"><i class="fas fa-sort"></i></span>
                        <select name="sort" class="form-select py-2">
                            <option value="nom" {% if currentSort|default('nom') == 'nom' %}selected{% endif %}>Trier par Nom</option>
                            <option value="matricule_fiscal" {% if currentSort|default('nom') == 'matricule_fiscal' %}selected{% endif %}>Trier par Matricule</option>
                            <option value="telephone" {% if currentSort|default('nom') == 'telephone' %}selected{% endif %}>Trier par Téléphone</option>
                        </select>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <select name="direction" class="form-select py-2">
                        <option value="asc" {% if currentDirection|default('asc') == 'asc' %}selected{% endif %}>Croissant</option>
                        <option value="desc" {% if currentDirection|default('asc') == 'desc' %}selected{% endif %}>Décroissant</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="submit" class="btn btn-apply-modern w-100 py-2">
                        Appliquer
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# Grille des fournisseurs #}
    <div class="row g-4">
        {% for f in fournisseurs %}
            <div class="col-md-4">
                <div class="card h-100 supplier-card-modern">
                    <div class="card-header-accent"></div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title fw-bold text-dark mb-0">{{ f.nom }}</h5>
                            <span class="badge bg-soft-primary px-3 py-2 rounded-pill">Actif</span>
                        </div>
                        <div class="supplier-info">
                            <div class="info-item">
                                <i class="fas fa-id-card text-muted me-2"></i>
                                <span><strong>Matricule :</strong> {{ f.matriculeFiscal }}</span>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-phone text-muted me-2"></i>
                                <span><strong>Téléphone :</strong> {{ f.telephone }}</span>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-building text-muted me-2"></i>
                                <span><strong>Franchise :</strong> {{ f.franchiseId ? f.franchiseId.nom : 'Aucune' }}</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 px-3 pb-4 pt-0 d-flex gap-1 flex-wrap">
                        <a href="{{ path('app_modifier_fournisseur', {'id': f.id}) }}" class="btn btn-outline-warning btn-action flex-grow-1">
                            <i class="fas fa-edit me-1"></i> Modifier
                        </a>
                        <a href="{{ path('app_fournisseur_pdf', {'id': f.id}) }}" class="btn btn-outline-success btn-action flex-grow-1">
                            <i class="fas fa-file-pdf me-1"></i> PDF
                        </a>
                        <a href="{{ path('app_fournisseur_delete', {'id': f.id}) }}" 
                           class="btn btn-outline-danger btn-action flex-grow-1" 
                           onclick="return confirm('Supprimer ce fournisseur ?')">
                            <i class="fas fa-trash-alt me-1"></i> Supprimer
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="empty-state">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted fs-5">Aucun fournisseur trouvé pour le moment.</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if pagesCount > 1 %}
        <nav class="mt-5">
            <ul class="pagination justify-content-center modern-pagination">
                {% for i in 1..pagesCount %}
                    <li class="page-item {% if i == currentPage %}active{% endif %}">
                        <a class="page-link" href="{{ path('app_afficher_front_fournisseur', {page: i, search: currentSearch|default(''), sort: currentSort|default('nom'), direction: currentDirection|default('asc')}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}

    {# Compteur Total #}
    <div class="mt-5 d-flex justify-content-center">
        <div class="total-counter-front shadow-sm">
            <span class="text">Nombre de partenaires :</span>
            <span class="number">{{ total }}</span>
        </div>
    </div>
</div>

<style>
/* Variables & Global */
:root {
    --primary-gradient: linear-gradient(135deg, #0d6efd 0%, #0043a8 100%);
    --success-gradient: linear-gradient(135deg, #198754 0%, #20c997 100%);
}

.bg-soft-primary {
    background-color: rgba(13, 110, 253, 0.1);
    color: #0d6efd;
    font-size: 0.75rem;
    font-weight: 700;
}

/* Boutons Modernes */
.btn-add-modern {
    background: var(--success-gradient);
    color: white !important;
    border: none;
    border-radius: 50px;
    padding: 12px 28px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(25, 135, 84, 0.2);
    transition: all 0.3s ease;
}
.btn-add-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(25, 135, 84, 0.3);
    filter: brightness(1.1);
}

.btn-apply-modern {
    background: var(--primary-gradient);
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s ease;
}
.btn-apply-modern:hover {
    filter: brightness(1.15);
    box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
}

/* Barre de filtrage */
.modern-filter-bar {
    border-radius: 15px;
    overflow: hidden;
}

/* Cartes Fournisseurs */
.supplier-card-modern {
    border: none;
    border-radius: 16px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    overflow: hidden;
    background: white;
}
.supplier-card-modern:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}
.card-header-accent {
    height: 5px;
    background: var(--primary-gradient);
}

.info-item {
    margin-bottom: 12px;
    font-size: 0.95rem;
}
.info-item i {
    width: 20px;
    text-align: center;
}

.btn-action {
    border-radius: 10px;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 8px 4px;
    white-space: nowrap;
}

/* Pagination Moderne */
.modern-pagination .page-item .page-link {
    border: none;
    margin: 0 3px;
    border-radius: 8px;
    color: #495057;
    font-weight: 600;
}
.modern-pagination .page-item.active .page-link {
    background: var(--primary-gradient);
    box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
}

/* Compteur Total */
.total-counter-front {
    display: inline-flex;
    align-items: center;
    background: white;
    padding: 12px 24px;
    border-radius: 50px;
    gap: 15px;
    border: 1px solid #e9ecef;
}
.total-counter-front .text {
    color: #6c757d;
    font-weight: 600;
    font-size: 0.9rem;
}
.total-counter-front .number {
    background: var(--primary-gradient);
    color: white;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: 800;
    font-size: 1.1rem;
}

/* News Ticker Extra Styles */
.news-ticker-container {
    display: flex;
    background: #141619;
    border-radius: 12px;
    overflow: hidden;
    height: 55px;
    align-items: center;
    border: 1px solid rgba(255,255,255,0.05);
}
.ticker-badge {
    background: #e63946;
    color: white;
    padding: 0 25px;
    height: 100%;
    display: flex;
    align-items: center;
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: 1.2px;
    z-index: 2;
    box-shadow: 8px 0 15px rgba(0,0,0,0.3);
}
.pulse-dot {
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    margin-right: 12px;
    box-shadow: 0 0 8px #fff;
    animation: ticker-pulse 1.5s infinite;
}
@keyframes ticker-pulse {
    0% { transform: scale(0.95); opacity: 0.8; }
    50% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(0.95); opacity: 0.8; }
}
.ticker-body {
    flex-grow: 1;
    height: 100%;
    position: relative;
    overflow: hidden;
}
#news-ticker-content {
    height: 100%;
}
.news-item {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 25px;
    color: #f8f9fa !important;
    text-decoration: none !important;
    font-weight: 500;
    font-size: 0.95rem;
    opacity: 0;
    visibility: hidden;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(30px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.news-item.active {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
}
.news-item:hover {
    color: #00e5ff !important;
}

/* Main Page Title */
.main-page-title {
    color: #1a1a1a;
    letter-spacing: -0.5px;
    position: relative;
    transition: all 0.3s ease;
}

[data-bs-theme="dark"] .main-page-title,
.dark-mode .main-page-title {
    color: #f8f9fa !important;
    text-shadow: 0 0 20px rgba(255,255,255,0.1);
}

/* Floating Widgets Shared */
.weather-widget, .ai-widget {
    position: fixed;
    right: 30px;
    width: 200px; /* Homogeneous width */
    height: 80px; /* Homogeneous height */
    border-radius: 20px;
    padding: 15px;
    display: flex !important;
    align-items: center;
    gap: 15px;
    z-index: 1000;
    border: 1px solid rgba(255, 255, 255, 0.4);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* Floating Weather Widget Styles */
.weather-widget {
    top: 45%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(15px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
    color: #1a1a1a;
}

.weather-widget:hover {
    transform: translateY(-55%) scale(1.05);
    background: #ffffff;
    box-shadow: 0 15px 40px rgba(0,0,0,0.12) !important;
}

.weather-icon-container {
    font-size: 2rem; /* Adjusted size */
    background: linear-gradient(135deg, #ffb703 0%, #fb8500 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 2px 4px rgba(251, 133, 0, 0.2));
}

.weather-info {
    text-align: left;
    flex-grow: 1;
}

.weather-top-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2px;
}

.weather-temp {
    font-size: 1.3rem;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1;
}

.weather-city {
    font-size: 0.6rem;
    font-weight: 800;
    color: #0d6efd;
    letter-spacing: 1px;
}

.weather-desc {
    font-size: 0.7rem;
    color: #6c757d;
    font-weight: 600;
    text-transform: capitalize;
}

/* AI Widget Styles */
.ai-widget {
    top: 58%;
    transform: translateY(-50%);
    background: linear-gradient(135deg, #212529 0%, #343a40 100%);
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2) !important;
    color: white;
}

.ai-widget:hover {
    transform: translateY(-55%) scale(1.05);
    box-shadow: 0 15px 40px rgba(0,0,0,0.3) !important;
}

.ai-icon-container {
    font-size: 1.8rem;
    position: relative;
    color: #00e5ff;
}

.ai-pulse {
    position: absolute;
    top: -2px;
    right: -2px;
    width: 10px;
    height: 10px;
    background: #00e5ff;
    border-radius: 50%;
    box-shadow: 0 0 8px #00e5ff;
    animation: ai-glow 1.5s infinite;
}

@keyframes ai-glow {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
    100% { transform: scale(1); opacity: 1; }
}

.ai-title {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 2px;
    color: #00e5ff;
}

.ai-status {
    font-size: 0.65rem;
    opacity: 0.8;
}

/* AI Report Panel */
.ai-report-panel {
    position: fixed;
    right: 30px;
    top: 15%;
    bottom: 15%;
    width: 350px;
    background: white;
    border-radius: 20px;
    z-index: 1001;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: translateX(450px);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}
.ai-report-panel.active {
    transform: translateX(0);
}
.ai-report-header {
    background: linear-gradient(135deg, #1a1a1a 0%, #333 100%);
    color: white;
    padding: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.ai-report-body {
    padding: 25px;
    overflow-y: auto;
    flex-grow: 1;
}
.insight-sub {
    font-size: 0.8rem;
    color: #6c757d;
}
.research-item {
    background: #fdfdfd;
    padding: 18px;
    border-radius: 16px;
    border: 1px solid #eee;
    transition: all 0.3s ease;
}
.research-item:hover {
    background: #fff;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}
.stock-badge {
    font-size: 0.7rem;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 50px;
}
.stock-badge.gain { background: rgba(25, 135, 84, 0.1); color: #198754; }
.stock-badge.loss { background: rgba(220, 53, 69, 0.1); color: #dc3545; }
.stock-badge.neutral { background: #f1f3f5; color: #6c757d; }

.finance-badge {
    display: inline-block;
    background: #e7f1ff;
    color: #0d6efd;
    font-size: 0.75rem;
    padding: 2px 12px;
    border-radius: 6px;
    font-weight: 600;
}
.research-title {
    font-weight: 800;
    font-size: 1rem;
    color: #1a1a1a;
}
.research-text {
    font-size: 0.85rem;
    color: #444;
    margin-bottom: 12px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.research-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #f1f3f5;
    padding-top: 10px;
}
.source {
    font-size: 0.7rem;
    color: #adb5bd;
    font-weight: 600;
}
.btn-more {
    font-size: 0.7rem;
    text-decoration: none;
    color: #0d6efd;
    font-weight: 700;
}
.op-2 { opacity: 0.2; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. Script News Ticker existant
    const newsItems = document.querySelectorAll('.news-item');
    if (newsItems.length > 0) {
        let currentIndex = 0;
        newsItems[currentIndex].classList.add('active');
        setInterval(() => {
            newsItems[currentIndex].classList.remove('active');
            currentIndex = (currentIndex + 1) % newsItems.length;
            newsItems[currentIndex].classList.add('active');
        }, 5000);
    }

    // 2. Script Météo (Désactivé : Migré vers PHP)
    // La météo est désormais gérée par le contrôleur Symfony pour une meilleure intégration.
});

function toggleAIReport() {
    const panel = document.getElementById('ai-report-panel');
    panel.classList.toggle('active');
}
</script>
{% endblock %}
