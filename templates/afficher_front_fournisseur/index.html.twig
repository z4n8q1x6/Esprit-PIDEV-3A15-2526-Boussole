{% extends 'front_base.html.twig' %}

{% block title %}Boussole - Liste des Fournisseurs{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Nos Fournisseurs</h2>
        <a href="{{ path('app_ajouter_fournisseur') }}" class="btn btn-success">
            <i class="fas fa-plus"></i>  Ajouter un fournisseur
        </a>
    </div>

    {# Barre de recherche et de tri #}
    <div class="card mb-4 border-0 shadow-sm bg-light">
        <div class="card-body py-3">
            <form method="get" action="{{ path('app_afficher_front_fournisseur') }}" class="row g-2 align-items-center">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <button type="submit" class="input-group-text bg-white cursor-pointer" title="Lancer la recherche" style="border: 1px solid #ced4da; border-right: none;">
                            <i class="fas fa-search text-primary"></i>
                        </button>
                        <input type="text" name="search" class="form-control" placeholder="Rechercher par nom ou matricule..." value="{{ currentSearch|default('') }}">
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-sort"></i></span>
                        <select name="sort" class="form-select">
                            <option value="nom" {% if currentSort|default('nom') == 'nom' %}selected{% endif %}>Défaut (Nom)</option>
                            <option value="matricule_fiscal" {% if currentSort|default('nom') == 'matricule_fiscal' %}selected{% endif %}>Matricule</option>
                            <option value="telephone" {% if currentSort|default('nom') == 'telephone' %}selected{% endif %}>Téléphone</option>
                        </select>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <select name="direction" class="form-select">
                        <option value="asc" {% if currentDirection|default('asc') == 'asc' %}selected{% endif %}>Croissant</option>
                        <option value="desc" {% if currentDirection|default('asc') == 'desc' %}selected{% endif %}>Décroissant</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Appliquer</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        {% for f in fournisseurs %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">{{ f.nom }}</h5>
                        <p class="card-text">
                            <strong>Matricule :</strong> {{ f.matriculeFiscal }}<br>
                            <strong>Tel :</strong> {{ f.telephone }}<br>
                            <strong>Franchise :</strong> {{ f.franchiseId ? f.franchiseId.nom : 'Aucune' }}
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex justify-content-between">
                        <a href="{{ path('app_modifier_fournisseur', {'id': f.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                        <a href="{{ path('app_fournisseur_delete', {'id': f.id}) }}" 
                           class="btn btn-sm btn-outline-danger" 
                           onclick="return confirm('Supprimer ce fournisseur ?')">Supprimer</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <p class="alert alert-info">Aucun fournisseur trouvé.</p>
            </div>
        {% endfor %}
    </div>

    {% if pagesCount > 1 %}
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                {% for i in 1..pagesCount %}
                    <li class="page-item {% if i == currentPage %}active{% endif %}">
                        <a class="page-link" href="{{ path('app_afficher_front_fournisseur', {page: i, search: currentSearch|default(''), sort: currentSort|default('nom'), direction: currentDirection|default('asc')}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}

    <div class="alert alert-dark mt-3">
        <strong>Total Fournisseurs affichés :</strong> {{ total }}
    </div>
</div>
{% endblock %}