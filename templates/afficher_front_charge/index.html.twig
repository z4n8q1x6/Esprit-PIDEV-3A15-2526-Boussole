{% extends 'front_base.html.twig' %}

{% block title %}Boussole - Mes Charges{% endblock %}

{% block content %}
<div class="container mt-4 pb-5">
    {# En-tête avec titre + bouton Ajouter #}
    <div class="d-flex justify-content-between align-items-center flex-nowrap mb-5 w-100 overflow-hidden">
        <h2 class="fw-bold main-page-title mb-0 text-nowrap">Mes Charges Financières</h2>
        <div class="d-flex align-items-center flex-nowrap gap-2">
            <button id="btn-urgence" class="btn btn-urgence-modern {% if hasUrgence|default(false) %}urgency-red-static{% endif %}" title="Score de Priorité Financière">
                <i class="fas fa-exclamation-triangle"></i>
            </button>
            <button id="btn-conseils" class="btn btn-info-modern">
                <i class="fas fa-lightbulb me-2"></i> Conseils
            </button>
            <a href="{{ path('app_ajouter_charge') }}" class="btn btn-add-modern">
                <i class="fas fa-plus-circle me-2"></i> Ajouter une charge
            </a>
        </div>
    </div>

    {# Barre de recherche et de tri #}
    <div class="card mb-5 border-0 shadow-sm modern-filter-bar">
        <div class="card-body p-3">
            <form method="get" action="{{ path('app_afficher_front_charge') }}" class="row g-3 align-items-center">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 py-2">
                            <i class="fas fa-search text-primary"></i>
                        </span>
                        <input type="text" name="q" class="form-control border-start-0 py-2" placeholder="Rechercher (titre, catégorie, statut)..." value="{{ search|default('') }}">
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white py-2"><i class="fas fa-sort"></i></span>
                        <select name="sort" class="form-select py-2">
                            <option value="id" {% if sort|default('id') == 'id' %}selected{% endif %}>Défaut (ID)</option>
                            <option value="montant" {% if sort|default('id') == 'montant' %}selected{% endif %}>Montant</option>
                            <option value="date_charge" {% if sort|default('id') == 'date_charge' %}selected{% endif %}>Date</option>
                            <option value="titre" {% if sort|default('id') == 'titre' %}selected{% endif %}>Titre</option>
                        </select>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <select name="dir" class="form-select py-2">
                        <option value="ASC" {% if dir|default('ASC') == 'ASC' %}selected{% endif %}>Croissant</option>
                        <option value="DESC" {% if dir|default('ASC') == 'DESC' %}selected{% endif %}>Décroissant</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="submit" class="btn btn-apply-modern w-100 py-2">Appliquer</button>
                </div>
            </form>
        </div>
    </div>

    {# Alertes de succès #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mb-4 rounded-pill px-4 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {# Grille des charges #}
    <div class="row g-4">
        {% for charge in charges %}
            <div class="col-md-4">
                <div class="card h-100 charge-card-modern">
                    {# Bordure de couleur dynamique selon statut #}
                    <div class="card-header-accent {% if charge.status_validation == 'Validé' %}bg-success{% elseif charge.status_validation == 'Refusé' %}bg-danger{% else %}bg-warning{% endif %}"></div>
                    
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="status-badge">
                                <span class="badge rounded-pill {% if charge.status_validation == 'Validé' %}bg-soft-success{% elseif charge.status_validation == 'Refusé' %}bg-soft-danger{% else %}bg-soft-warning{% endif %}">
                                    {{ charge.status_validation }}
                                </span>
                            </div>
                            <small class="text-muted fw-bold"><i class="far fa-calendar-alt me-1"></i> {{ charge.date_charge ? charge.date_charge|date('d/m/Y') : '' }}</small>
                        </div>
                        
                        <h5 class="card-title fw-bold text-dark mb-2">{{ charge.titre }}</h5>
                        <div class="amount-display mb-3">
                            <span class="h3 fw-bold text-primary mb-0">{{ charge.montant|number_format(2, ',', ' ') }}</span>
                            <span class="text-muted ms-1">TND</span>
                        </div>
                        
                        <hr class="my-3 opacity-10">
                        
                        <div class="charge-meta">
                            <div class="meta-item mb-2">
                                <i class="fas fa-tag text-muted me-2"></i>
                                <span class="small text-secondary">Catégorie : <strong>{{ charge.type }}</strong></span>
                            </div>
                            <div class="meta-item">
                                <i class="fas fa-building text-muted me-2"></i>
                                <span class="small text-secondary">Franchise : <strong>{{ (charge.franchise_id and charge.franchise_id.nom) ? charge.franchise_id.nom : 'Aucune' }}</strong></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-white border-0 px-3 pb-4 pt-0 d-flex gap-1 flex-wrap">
                        <a href="{{ path('app_modifier_charge', {'id': charge.id}) }}" class="btn btn-outline-warning btn-action flex-grow-1">
                            <i class="fas fa-edit me-1"></i> Modifier
                        </a>
                        <a href="{{ path('app_charge_pdf', {'id': charge.id}) }}" class="btn btn-outline-info btn-action flex-grow-1">
                            <i class="fas fa-file-pdf me-1"></i> PDF
                        </a>
                        <a href="{{ path('app_charge_delete', {'id': charge.id}) }}" 
                           class="btn btn-outline-danger btn-action flex-grow-1" 
                           onclick="return confirm('Supprimer cette charge ?')">
                            <i class="fas fa-trash-alt me-1"></i> Supprimer
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="empty-state">
                    <i class="fas fa-receipt fa-3x text-muted mb-3 opacity-50"></i>
                    <p class="text-muted fs-5">Aucune charge financière enregistrée.</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if pagesCount > 1 %}
        <nav class="mt-5">
            <ul class="pagination justify-content-center modern-pagination">
                {% for i in 1..pagesCount %}
                    <li class="page-item {% if i == currentPage %}active{% endif %}">
                        <a class="page-link" href="{{ path('app_afficher_front_charge', {page: i, q: search|default(''), sort: sort|default('id'), dir: dir|default('ASC')}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}

    {# Compteur Total Moderne #}
    <div class="mt-5 d-flex justify-content-center">
        <div class="total-counter-front shadow-sm">
            <span class="text">Montant Total Global :</span>
            <span class="number-box">{{ total|number_format(2, ',', ' ') }} <small>TND</small></span>
        </div>
    </div>
</div>

<style>
/* Main Page Title */
.main-page-title {
    color: #1a1a1a;
    letter-spacing: -0.5px;
    position: relative;
    transition: all 0.3s ease;
}

[data-bs-theme="dark"] .main-page-title,
.dark-mode .main-page-title {
    color: #f8f9fa !important;
    text-shadow: 0 0 20px rgba(255,255,255,0.1);
}

/* Variables & Global */
:root {
    --primary-gradient: linear-gradient(135deg, #0d6efd 0%, #0043a8 100%);
    --success-gradient: linear-gradient(135deg, #198754 0%, #20c997 100%);
    --warning-gradient: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
}

/* Status Badges Soft */
.bg-soft-success { background-color: rgba(25, 135, 84, 0.1); color: #198754; font-weight: 700; }
.bg-soft-danger { background-color: rgba(220, 53, 69, 0.1); color: #dc3545; font-weight: 700; }
.bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); color: #997404; font-weight: 700; }

/* Boutons Modernes */
.btn-add-modern {
    background: var(--success-gradient);
    color: white !important;
    border: none;
    border-radius: 50px;
    padding: 12px 28px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(25, 135, 84, 0.2);
    transition: all 0.3s ease;
}
.btn-add-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(25, 135, 84, 0.3);
    filter: brightness(1.1);
}

.btn-apply-modern {
    background: var(--primary-gradient);
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.2s ease;
}
.btn-apply-modern:hover {
    filter: brightness(1.15);
    box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
}

/* Barre de filtrage */
.modern-filter-bar { border-radius: 15px; }

/* Cartes Charges */
.charge-card-modern {
    border: none;
    border-radius: 16px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    background: white;
    overflow: hidden;
}
.charge-card-modern:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}
.card-header-accent { height: 6px; }

.btn-action {
    border-radius: 10px;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 8px 4px;
    white-space: nowrap;
}

/* Pagination Moderne */
.modern-pagination .page-item .page-link {
    border: none;
    margin: 0 3px;
    border-radius: 8px;
    color: #495057;
    font-weight: 600;
}
.modern-pagination .page-item.active .page-link {
    background: var(--primary-gradient);
    box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
}

/* Compteur Total */
.total-counter-front {
    display: inline-flex;
    align-items: center;
    background: white;
    padding: 12px 24px;
    border-radius: 50px;
    gap: 15px;
    border: 1px solid #e9ecef;
}
.total-counter-front .text { color: #6c757d; font-weight: 600; font-size: 1rem; }
.total-counter-front .number-box {
    background: var(--primary-gradient);
    color: white;
    padding: 6px 18px;
    border-radius: 30px;
    font-weight: 800;
    font-size: 1.2rem;
    box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2);
}
.btn-info-modern {
    background: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);
    color: white !important;
    border: none;
    border-radius: 50px;
    padding: 12px 28px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(13, 202, 240, 0.2);
    transition: all 0.3s ease;
}
.btn-info-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(13, 202, 240, 0.3);
    filter: brightness(1.1);
}

/* Bouton Urgence Priorité */
.btn-urgence-modern {
    background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    color: white !important;
    border: none;
    border-radius: 50px;
    padding: 12px 22px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(108, 117, 125, 0.2);
    transition: all 0.3s ease;
}
.btn-urgence-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(108, 117, 125, 0.3);
}
.urgency-red-static {
    background: linear-gradient(135deg, #dc3545 0%, #a71d2a 100%) !important;
    box-shadow: 0 4px 15px rgba(220, 53, 69, 0.4) !important;
}

/* Floating Widgets Styles */
.stats-floating-wrapper {
    position: fixed;
    right: 60px; /* Poussées légèrement vers la gauche */
    top: 50%;
    transform: translateY(-50%);
    z-index: 9999;
    width: 240px; /* Taille intermédiaire */
}
.stats-glass-widget {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 15px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    transition: all 0.3s ease;
}
.stats-glass-widget:hover {
    transform: scale(1.05);
    background: #ffffff;
}
.widget-header {
    font-size: 0.7rem;
    font-weight: 800;
    color: #1d3b53;
    letter-spacing: 1px;
    text-align: center;
    margin-bottom: 15px;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    padding-bottom: 8px;
}
.chart-container { min-height: 200px; width: 100%; } /* Taille intermédiaire */
.stats-floating-wrapper .apexcharts-canvas { margin: 0 auto; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    /* 1. Bouton Conseils Financiers */
    const btnConseils = document.getElementById('btn-conseils');
    if (btnConseils) {
        btnConseils.addEventListener('click', async () => {
            btnConseils.disabled = true;
            const originalHTML = btnConseils.innerHTML;
            btnConseils.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Analyse...';

            try {
                const urlParams = new URLSearchParams(window.location.search);
                const query = urlParams.get('q') || '';
                const response = await fetch(`{{ path('app_front_charge_conseils') }}?q=${encodeURIComponent(query)}`);
                const data = await response.json();

                if (data.success) {
                    let htmlContent = `
                        <div class="text-start" style="font-family: 'Heebo', sans-serif;">
                            <!-- Header Card -->
                            <div class="mb-4 p-3 rounded-3 shadow-sm" style="background: #1d3b53; border-top: 4px solid #00e5ff;">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small text-uppercase fw-bold text-white-50">Résumé de l'Analyse</span>
                                    <span class="badge bg-soft-info text-info" style="font-size: 0.7rem; background: rgba(0, 229, 255, 0.1) !important; color: #00e5ff !important;">
                                        Basé sur ${data.count} charges
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between align-items-baseline mt-2">
                                    <h6 class="mb-0 text-white opacity-75">Dépenses Totales :</h6>
                                    <h4 class="mb-0 fw-bold" style="color: #00e5ff;">${data.total} <small class="fw-normal" style="font-size: 0.8rem;">TND</small></h4>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top border-secondary border-opacity-25">
                                    <span class="small text-white-50">Moyenne par dépense :</span>
                                    <span class="small fw-bold text-white">${data.moyenne} TND</span>
                                </div>
                            </div>

                            <!-- Categories -->
                            <div class="mb-2 px-1">
                                <h6 class="fw-bold text-dark mb-3">
                                    <i class="fas fa-chart-pie me-2" style="color: #1d3b53;"></i> 
                                    Répartition budgétaire :
                                </h6>
                                
                                ${data.stats.map(stat => {
                                    const barColor = stat.pourcentage > 40 ? '#dc3545' : '#198754';
                                    const badgeClass = stat.pourcentage > 40 ? 'bg-danger' : 'bg-success';
                                    
                                    return `
                                    <div class="category-item mb-4">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-bold text-dark" style="font-size: 0.95rem;">${stat.label}</span>
                                            <span class="badge ${badgeClass} shadow-sm px-2 py-1" style="font-size: 0.75rem;">${stat.pourcentage}%</span>
                                        </div>
                                        <div class="progress" style="height: 8px; border-radius: 10px; background: #e9ecef;">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                                 role="progressbar" 
                                                 style="width: ${stat.pourcentage}%; background-color: ${barColor};" 
                                                 aria-valuenow="${stat.pourcentage}" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100"></div>
                                        </div>
                                        <div class="mt-2 p-2 rounded bg-white border border-light-subtle shadow-sm border-start border-3" style="border-color: ${barColor} !important;">
                                            <p class="mb-0 small text-dark" style="line-height: 1.5; font-size: 0.85rem;">
                                                <i class="fas fa-info-circle me-1 opacity-50"></i> ${stat.conseil}
                                            </p>
                                        </div>
                                    </div>`;
                                }).join('')}
                            </div>
                        </div>`;

                    Swal.fire({
                        title: '<h4 class="fw-bold mb-0">📊 Analyse Avancée</h4>',
                        html: htmlContent,
                        confirmButtonText: '<i class="fas fa-check me-2"></i> J\'ai compris',
                        confirmButtonColor: '#1d3b53',
                        width: '580px',
                        padding: '1.5rem',
                        background: '#ffffff',
                        showCloseButton: true,
                        customClass: {
                            popup: 'rounded-4 shadow-lg border-0',
                            confirmButton: 'px-4 py-2 rounded-3'
                        }
                    });
                }
            } catch (error) {
                console.error(error);
            } finally {
                btnConseils.disabled = false;
                btnConseils.innerHTML = originalHTML;
            }
        });
    }

    /* 2. Statistiques ApexCharts */
    const initCharts = () => {
        if (typeof ApexCharts === 'undefined') return;

        const statsStatus = {{ statsStatus|json_encode|raw }};
        const statsType = {{ statsType|json_encode|raw }};
        const hasData = Object.values(statsStatus).some(v => v > 0) || Object.values(statsType).some(v => v > 0);

        if (!hasData) {
            document.querySelectorAll(".chart-container").forEach(el => el.innerHTML = '<div class="small text-muted py-4">Aucune donnée</div>');
            return;
        }

        const common = {
            chart: { height: 200, toolbar: { show: false } },
            legend: { show: false },
            dataLabels: { enabled: true, style: { fontSize: '10px' } } /* Écriture intermédiaire */
        };

        new ApexCharts(document.querySelector("#chart-status"), {
            ...common,
            series: Object.values(statsStatus),
            labels: Object.keys(statsStatus),
            chart: { ...common.chart, type: 'donut' },
            colors: ['#198754', '#dc3545', '#ffc107']
        }).render();

        new ApexCharts(document.querySelector("#chart-type"), {
            ...common,
            series: Object.values(statsType),
            labels: Object.keys(statsType),
            chart: { ...common.chart, type: 'pie' },
            colors: ['#e83e8c', '#6f42c1', '#0d6efd']
        }).render();
    };

    if (typeof ApexCharts === 'undefined') {
        const sc = document.createElement('script');
        sc.src = 'https://cdn.jsdelivr.net/npm/apexcharts';
        sc.onload = initCharts;
        document.head.appendChild(sc);
    } else {
        initCharts();
    }

    /* 3. Bouton Priorité Financière (Score) */
    const btnUrgence = document.getElementById('btn-urgence');
    if (btnUrgence) {
        const scoredCharges = {{ scoredCharges|default([])|json_encode|raw }};
        const seuilUrgence = {{ seuilUrgence|default(30) }};
        const hasUrgenceBool = {{ hasUrgence|default(false) ? 'true' : 'false' }};
        
        btnUrgence.addEventListener('click', () => {
            let listHtml = '';
            if (scoredCharges.length === 0) {
                listHtml = '<p class="text-muted text-center mt-3">Aucune charge à évaluer.</p>';
            } else {
                listHtml = '<div class="list-group mt-3" style="max-height: 400px; overflow-y: auto;">';
                scoredCharges.forEach(charge => {
                    const isUrgent = charge.score >= seuilUrgence;
                    const badgeClass = isUrgent ? 'bg-danger' : 'bg-success';
                    const icon = isUrgent ? '<i class="fas fa-exclamation-circle text-danger me-2"></i>' : '<i class="fas fa-check-circle text-success me-2"></i>';
                    
                    listHtml += `
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2 rounded border ${isUrgent ? 'border-danger border-opacity-50' : ''}">
                        <div class="d-flex flex-column text-start flex-grow-1">
                            <span class="fw-bold">${icon} ${charge.titre}</span>
                            <small class="text-secondary fw-semibold"><i class="far fa-calendar-alt me-1"></i> Ajoutée le ${charge.date_str} - Statut: <strong>${charge.status}</strong></small>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span class="text-dark fw-bold border-end pe-3" style="font-size: 1.1rem;">${Number(charge.montant).toFixed(2)} TND</span>
                            <div class="text-center" style="min-width: 80px;">
                                <span class="d-block small text-secondary fw-bold mb-1" style="font-size: 9px; text-transform: uppercase;">Score de priorité</span>
                                <span class="badge ${badgeClass} rounded-pill fs-6 px-3 shadow-sm">${charge.score} Pts</span>
                            </div>
                        </div>
                    </div>`;
                });
                listHtml += '</div>';
            }

            Swal.fire({
                title: '<h4 class="fw-bold text-dark mb-0"><i class="fas fa-tachometer-alt me-2 text-primary"></i> Score de Priorité Financière</h4>',
                html: `
                    <div class="alert alert-info border-0 shadow-sm text-start" role="alert" style="background-color: #e0f2fe; color: #0369a1;">
                        <i class="fas fa-info-circle me-2"></i> <strong>Calcul :</strong> Score = Ancienneté (en jours) majorée selon le statut (+40% Validé, +20% En attente).
                        <hr class="border-info opacity-50 my-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small fw-bold text-dark">Seuil d'alerte : ${seuilUrgence} pts</span>
                            <span class="badge ${hasUrgenceBool ? 'bg-danger' : 'bg-success'} px-2 py-1">${hasUrgenceBool ? "SOUS TENSION" : "SCORE NORMAL"}</span>
                        </div>
                    </div>
                    ${listHtml}
                `,
                width: '750px',
                confirmButtonText: '<i class="fas fa-check me-2"></i> Bien reçu',
                confirmButtonColor: '#1d3b53',
                background: '#f8f9fa',
                customClass: {
                    popup: 'rounded-4 shadow-lg border-0',
                    confirmButton: 'px-4 py-2 rounded-3 fw-bold'
                }
            });
        });
    }
});
</script>

{# Widgets de Statistiques Flottants #}
<div class="stats-floating-wrapper">
    <div class="stats-glass-widget shadow-lg mb-4">
        <div class="widget-header">STATUT</div>
        <div id="chart-status" class="chart-container"></div>
    </div>
    <div class="stats-glass-widget shadow-lg">
        <div class="widget-header">CATEGORIE</div>
        <div id="chart-type" class="chart-container"></div>
    </div>
</div>
{% endblock %}