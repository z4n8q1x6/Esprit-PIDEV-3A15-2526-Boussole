{% extends 'front_base.html.twig' %}

{% block title %}Boussole - Mes Charges{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Mes Charges Financières</h2>
        <div>
            <span class="badge bg-primary fs-6 me-3">Total Global : {{ total|number_format(2, ',', ' ') }} TND</span>
            <a href="{{ path('app_ajouter_charge') }}" class="btn btn-success"><i class="fas fa-plus me-1"></i> Ajouter une charge</a>
        </div>
    </div>

    {# Barre de recherche et de tri #}
    <div class="card mb-4 border-0 shadow-sm bg-light">
        <div class="card-body py-3">
            <form method="get" action="{{ path('app_afficher_front_charge') }}" class="row g-2 align-items-center">
                <div class="col-12 col-md-5">
                    <div class="input-group">
                        <button type="submit" class="input-group-text bg-white cursor-pointer" title="Lancer la recherche" style="border: 1px solid #ced4da; border-right: none;">
                            <i class="fas fa-search text-primary"></i>
                        </button>
                        <input type="text" name="q" class="form-control" placeholder="Rechercher (titre, catégorie, statut)..." value="{{ search|default('') }}">
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-sort"></i></span>
                        <select name="sort" class="form-select">
                            <option value="id" {% if sort|default('id') == 'id' %}selected{% endif %}>Défaut (ID)</option>
                            <option value="montant" {% if sort|default('id') == 'montant' %}selected{% endif %}>Montant</option>
                            <option value="date_charge" {% if sort|default('id') == 'date_charge' %}selected{% endif %}>Date</option>
                            <option value="titre" {% if sort|default('id') == 'titre' %}selected{% endif %}>Titre</option>
                        </select>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <select name="dir" class="form-select">
                        <option value="ASC" {% if dir|default('ASC') == 'ASC' %}selected{% endif %}>Croissant</option>
                        <option value="DESC" {% if dir|default('ASC') == 'DESC' %}selected{% endif %}>Décroissant</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Appliquer</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4">
        {% for charge in charges %}
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            {# Affichage du Statut avec couleur dynamique #}
                            <span class="badge {% if charge.statusValidation == 'VALIDE' %}bg-success{% elseif charge.statusValidation == 'REFUSE' %}bg-danger{% else %}bg-warning{% endif %}">
                                {{ charge.statusValidation }}
                            </span>
                            <small class="text-muted">{{ charge.dateCharge|date('d/m/Y') }}</small>
                        </div>
                        <h5 class="card-title text-primary">{{ charge.titre }}</h5>
                        <p class="card-text h4">{{ charge.montant }} TND</p>
                        <hr>
                        <p class="small text-muted mb-1">Catégorie : {{ charge.type }}</p>
                        <p class="small text-muted">Franchise : {{ charge.franchiseId ? charge.franchiseId.nom : 'Aucune' }}</p>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">Aucune charge enregistrée pour le moment.</div>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    {% if pagesCount > 1 %}
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                {% for i in 1..pagesCount %}
                    <li class="page-item {% if i == currentPage %}active{% endif %}">
                        <a class="page-link" href="{{ path('app_afficher_front_charge', {page: i, q: search|default(''), sort: sort|default('id'), dir: dir|default('ASC')}) }}">{{ i }}</a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}