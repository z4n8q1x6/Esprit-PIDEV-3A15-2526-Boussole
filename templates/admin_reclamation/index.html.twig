{% extends 'back_base.html.twig' %}

{% block title %}Liste des Réclamations{% endblock %}

{% block body %}
<div class="page-content-wrapper border">

    <div class="row mb-3">
        <div class="col-12">
            <h1 class="h3 mb-2 mb-sm-0">Liste des Réclamations</h1>
        </div>
    </div>

    <div class="card bg-transparent border">



        <div class="card-body">
            <div class="mb-3 pb-0">
                <form method="get" class="d-flex gap-2">
                    <input
                            class="form-control form-control-sm"
                            placeholder="Rechercher par sujet..."
                            type="text"
                            name="q"
                            value="{{ app.request.query.get('q') }}"
                            >
                            <button type="submit" class="btn btn-primary btn-sm px-3">
                                Search
                            </button>
                    {% if app.request.query.get('q') is not empty %}
                    <a href="{{ path('admin_reclamation_index') }}" class="btn btn-outline-secondary">
                        Clear
                    </a>
                    {% endif %}
                </form>
            </div>
            <div class="table-responsive border-0">
                <table id="table-reclamation-admin" class="table align-middle mb-0 table-hover" style="font-size: 0.95rem;">
                    <thead class="table-light">
                        {% set currentSort = app.request.query.get('sort', 'id') %}
                        {% set currentDir = app.request.query.get('direction', 'desc') %}
                        {% set query = app.request.query.get('q') %}
                        <tr>
                            <th scope="col" class="border-0 rounded-start ps-4 fw-600 text-uppercase letter-spacing" style="cursor: pointer;">
                                {% set isSujet = currentSort == 'sujet' %}
                                {% set nextDir = (isSujet and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('admin_reclamation_index', {q: query, sort: 'sujet', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Sujet
                                    {% if isSujet %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>
                            <th scope="col" class="border-0 ps-3 fw-600 text-uppercase letter-spacing" style="cursor: pointer;">
                                {% set isDesc = currentSort == 'description' %}
                                {% set nextDir = (isDesc and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('admin_reclamation_index', {q: query, sort: 'description', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Description
                                    {% if isDesc %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>
                            <th scope="col" class="border-0 ps-3 fw-600 text-uppercase letter-spacing" style="cursor: pointer;">
                                {% set isStatut = currentSort == 'statut' %}
                                {% set nextDir = (isStatut and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('admin_reclamation_index', {q: query, sort: 'statut', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Statut
                                    {% if isStatut %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>
                            <th scope="col" class="border-0 ps-3 fw-600 text-uppercase letter-spacing text-center" style="cursor: pointer;">
                                {% set isDate = currentSort == 'date_creation' %}
                                {% set nextDir = (isDate and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('admin_reclamation_index', {q: query, sort: 'date_creation', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Date
                                    {% if isDate %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>
                            <th scope="col" class="border-0 rounded-end text-center ps-3 fw-600 text-uppercase letter-spacing">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for reclamation in reclamations %}
                            <tr class="border-bottom">
                                <td class="ps-4 py-3">
                                    <h6 class="mb-0 fw-500">
                                        <span class="text-primary">{{ reclamation.sujet }}</span>
                                    </h6>
                                </td>

                                <td class="text-muted ps-3 py-3">
                                    <div style="min-width: 200px; max-width: 300px; max-height: 80px; overflow-y: auto; word-break: break-word;">
                                        {{ reclamation.description }}
                                    </div>
                                </td>

<td class="ps-3 py-3">
    <form method="post" action="{{ path('admin_reclamation_edit', {'id': reclamation.id}) }}" class="d-flex align-items-center gap-2">
        <input type="hidden" name="token" value="{{ csrf_token('edit-item') }}">
<select name="statut" class="form-select" style="min-width: 155px; background-color: #2b2b2b; color: #fff; border: 1px solid #444; border-radius: 8px;">
    <option value="EN_ATTENTE" {{ reclamation.statut == 'EN_ATTENTE' ? 'selected' }}>En attente</option>
    <option value="EN_COURS" {{ reclamation.statut == 'EN_COURS' ? 'selected' }}>En cours</option>
    <option value="RESOLU" {{ reclamation.statut == 'RESOLU' ? 'selected' }}>Résolu</option>
</select>
        <button type="submit" class="btn btn-sm btn-light mb-0 shadow-none flex-shrink-0">
            <i class="bi bi-check-lg"></i>
        </button>
    </form>
</td>

                                <td class="text-center ps-3 py-3">
                                    <div class="small">
                                        <span class="fw-500 d-block">{{ reclamation.date_creation|date('d/m/Y') }}</span>
                                        <span class="text-muted" style="font-size: 0.8rem;">{{ reclamation.date_creation|date('H:i') }}</span>
                                    </div>
                                </td>

                                <td class="text-center ps-3 py-3">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-danger-soft delete-btn" data-bs-toggle="modal" data-bs-target="#deleteModal" data-delete-url="{{ path('admin_reclamation_delete', {'id': reclamation.id}) }}" data-item-name="{{ reclamation.sujet }}" data-csrf-token="{{ csrf_token('delete-item') }}">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                        <button type="button" class="btn btn-secondary analyse-btn" data-reclamation-id="{{ reclamation.id }}" data-csrf-token="{{ csrf_token('analyse-item') }}" data-sujet="{{ reclamation.sujet }}">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-claude" viewBox="0 0 16 16">
                                                <path d="m3.127 10.604 3.135-1.76.053-.153-.053-.085H6.11l-.525-.032-1.791-.048-1.554-.065-1.505-.08-.38-.081L0 7.832l.036-.234.32-.214.455.04 1.009.069 1.513.105 1.097.064 1.626.17h.259l.036-.105-.089-.065-.068-.064-1.566-1.062-1.695-1.121-.887-.646-.48-.327-.243-.306-.104-.67.435-.48.585.04.15.04.593.456 1.267.981 1.654 1.218.242.202.097-.068.012-.049-.109-.181-.9-1.626-.96-1.655-.428-.686-.113-.411a2 2 0 0 1-.068-.484l.496-.674L4.446 0l.662.089.279.242.411.94.666 1.48 1.033 2.014.302.597.162.553.06.17h.105v-.097l.085-1.134.157-1.392.154-1.792.052-.504.25-.605.497-.327.387.186.319.456-.045.294-.19 1.23-.37 1.93-.243 1.29h.142l.161-.16.654-.868 1.097-1.372.484-.545.565-.601.363-.287h.686l.505.751-.226.775-.707.895-.585.759-.839 1.13-.524.904.048.072.125-.012 1.897-.403 1.024-.186 1.223-.21.553.258.06.263-.218.536-1.307.323-1.533.307-2.284.54-.028.02.032.04 1.029.098.44.024h1.077l2.005.15.525.346.315.424-.053.323-.807.411-3.631-.863-.872-.218h-.12v.073l.726.71 1.331 1.202 1.667 1.55.084.383-.214.302-.226-.032-1.464-1.101-.565-.497-1.28-1.077h-.084v.113l.295.432 1.557 2.34.08.718-.112.234-.404.141-.444-.08-.911-1.28-.94-1.44-.759-1.291-.093.053-.448 4.821-.21.246-.484.186-.403-.307-.214-.496.214-.98.258-1.28.21-1.016.19-1.263.112-.42-.008-.028-.092.012-.953 1.307-1.448 1.957-1.146 1.227-.274.109-.477-.247.045-.44.266-.39 1.586-2.018.956-1.25.617-.723-.004-.105h-.036l-4.212 2.736-.75.096-.324-.302.04-.496.154-.162 1.267-.871z"/>
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">Aucune réclamation trouvée.</div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            </div>
        <div class="card-footer bg-transparent border-top">
            <small class="text-muted">Total: {{ reclamations|length }} réclamations enregistrées.</small>
        </div>
    </div>
</div>

<!-- Modern Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-600" id="deleteModalLabel">Confirmer la suppression</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-3">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                </div>
                <p class="text-muted mb-2">Êtes-vous sûr de vouloir supprimer ?</p>
                <p class="fw-600 text" id="deleteItemName"></p>
            </div>
            <div class="modal-footer bg-light border-top-0 gap-2">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Supprimer</button>
            </div>
        </div>
    </div>
</div>

<!-- Analysis Modal -->
<div class="modal fade" id="analysisModal" tabindex="-1" aria-labelledby="analysisModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="analysisModalLabel">Analyse de Réclamation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="analysisContent">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Chargement...</span>
                        </div>
                        <p class="mt-2 text-muted">Analyse en cours...</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Delete modal logic
    const deleteModal = document.getElementById('deleteModal');
    const deleteButtons = document.querySelectorAll('.delete-btn');
    let currentDeleteUrl = null;
    let currentCsrfToken = null;

    deleteButtons.forEach(button => {
        button.addEventListener('click', function() {
            currentDeleteUrl = this.dataset.deleteUrl;
            currentCsrfToken = this.dataset.csrfToken;
            const itemName = this.dataset.itemName;
            document.getElementById('deleteItemName').textContent = itemName;
        });
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (currentDeleteUrl && currentCsrfToken) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = currentDeleteUrl;

            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = 'token';
            tokenInput.value = currentCsrfToken;

            form.appendChild(tokenInput);
            document.body.appendChild(form);
            form.submit();
        }
    });

    // Analysis modal logic
    const analyseButtons = document.querySelectorAll('.analyse-btn');
    const analysisModal = new bootstrap.Modal(document.getElementById('analysisModal'));
    const analysisContent = document.getElementById('analysisContent');

    analyseButtons.forEach(button => {
        button.addEventListener('click', async function(e) {
            e.preventDefault();
            const reclamationId = this.dataset.reclamationId;
            const csrfToken = this.dataset.csrfToken;
            const sujet = this.dataset.sujet;

            // Show loading state
            analysisContent.innerHTML = `
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement...</span>
                    </div>
                    <p class="mt-2 text-muted">Analyse en cours...</p>
                </div>
            `;
            analysisModal.show();

            try {
                const response = await fetch(`/admin/reclamations/${reclamationId}/analyse`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `token=${encodeURIComponent(csrfToken)}`
                });

                const data = await response.json();

                if (data.success) {
                    // Format the analysis text
                    const analysisText = data.analysis
                        .split('\n')
                        .map(line => line.trim())
                        .filter(line => line)
                        .join('<br>');

                    analysisContent.innerHTML = `
                        <div>
                            <h6 class="text-primary mb-3">${data.sujet}</h6>
                            <div class="alert alert-info" role="alert">
                                <strong>Analyse IA:</strong><br>
                                ${analysisText}
                            </div>
                        </div>
                    `;
                } else {
                    analysisContent.innerHTML = `
                        <div class="alert alert-danger" role="alert">
                            <strong>Erreur:</strong> ${data.error || 'Une erreur est survenue lors de l\'analyse.'}
                        </div>
                    `;
                }
            } catch (error) {
                analysisContent.innerHTML = `
                    <div class="alert alert-danger" role="alert">
                        <strong>Erreur:</strong> ${error.message || 'Une erreur réseau est survenue.'}
                    </div>
                `;
                console.error('Analyse error:', error);
            }
        });
    });
});
</script>

{% endblock %}


