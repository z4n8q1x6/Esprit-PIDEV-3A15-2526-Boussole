{% extends 'front_base.html.twig' %}

{% block title %}Historique des transactions{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">    
        <div>
            <h1 class="h3 mb-0">Historique des transactions</h1>   
            <p class="text-muted">Historique des transactions</p>   
        </div>
        <div>
            <a href="{{ path('app_transaction_index') }}" class="btn btn-outline-info">
                <i class="bi bi-arrow-left me-2"></i>Retour au Dashboard      
            </a>
        </div>
    </div>
</div>

<!-- Main Card -->
<div class="card border shadow mb-4">
    <div class="card-body p-4">
        <!-- Filtres -->
        <form id="filterForm" method="get" action="{{ path('app_transaction_historique') }}"> 
            <div class="row align-items-end g-3 mb-4">
                <div class="col-md-3">
                    <label class="text-muted small mb-1">Période</label>   
                    <div class="dropdown">
                        <button class="form-select text-start d-flex justify-content-between align-items-center rounded-pill w-100" type="button" id="periodeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <span><i class="bi bi-calendar3 text-primary me-2"></i> <span id="currentPeriodLabel">Période : Ce Mois</span></span>        
                            <i class="bi bi-chevron-down ms-1"></i>
                        </button>
                        <ul class="dropdown-menu shadow border p-3 mt-2" aria-labelledby="periodeDropdown" style="min-width: 320px; border-radius: 12px; z-index: 1050;">
                            <li><a class="dropdown-item py-2 px-3 rounded mb-1 period-option {% if currentPeriode|default('this_month') == 'this_month' %}active{% endif %}" href="#" data-value="this_month">Ce Mois</a></li>
                            <li><a class="dropdown-item py-2 px-3 rounded mb-1 period-option {% if currentPeriode|default('this_month') == 'last_month' %}active{% endif %}" href="#" data-value="last_month">Mois Dernier</a></li>       
                            <li><a class="dropdown-item py-2 px-3 rounded mb-1 period-option {% if currentPeriode|default('this_month') == 'this_year' %}active{% endif %}" href="#" data-value="this_year">Cette Année</a></li>       
                            <li><a class="dropdown-item py-2 px-3 rounded mb-2 period-option {% if currentPeriode|default('this_month') == 'all' %}active{% endif %}" href="#" data-value="all">Tout</a></li>
                            <li><hr class="dropdown-divider mb-3"></li>
                            <li class="px-2">
                                <span class="text-muted small fw-bold d-block mb-2">Plage personnalisée</span>
                                <div class="row gx-2">
                                    <div class="col-5">
                                        <input type="date" class="form-control form-control-sm rounded custom-date-input" name="date_start" id="customDateStart" value="{{ currentStart|default('') }}">
                                    </div>
                                    <div class="col-5">
                                        <input type="date" class="form-control form-control-sm rounded custom-date-input" name="date_end" id="customDateEnd" value="{{ currentEnd|default('') }}">
                                    </div>
                                    <div class="col-2">
                                        <button type="button" class="btn btn-info w-100 rounded text-center text-dark fw-bold px-0 custom-date-btn" style="background-color: #0dcaf0; border-color: #0dcaf0;">OK</button>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <input type="hidden" name="periode" id="periodeValue" value="{{ currentPeriode|default('this_month') }}">
                </div>
                <div class="col-md-3">
                    <label class="text-muted small mb-1">Type</label>
                    <select name="type" class="form-select rounded-pill" id="typeFilter">
                        <option value="TOUT" {% if currentType is defined and currentType == 'TOUT' %}selected{% endif %}>TOUT</option>
                        <option value="RECETTE" {% if currentType is defined and currentType == 'RECETTE' %}selected{% endif %}>RECETTE</option>
                        <option value="DEPENSE" {% if currentType is defined and currentType == 'DEPENSE' %}selected{% endif %}>DÉPENSE</option>        
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0 text-muted ps-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" value="{{ currentSearch|default('') }}" class="form-control rounded-pill" placeholder="Rechercher...">
                    </div>
                </div>
                <div class="col-md-3 d-flex justify-content-end align-items-center">
                    <a href="#" id="resetFiltersBtn" class="text-muted me-3 text-decoration-none small">Réinitialiser</a>
                    <button type="submit" class="d-none"></button>
                    <a href="{{ path('app_export_excel') }}" id="btn-export-excel" class="btn btn-primary rounded-pill fw-bold px-4" style="background-color: #0d6efd; color: white; border: none;"><i class="bi bi-file-earmark-excel me-1"></i>Exporter Excel</a>
                </div>
            </div>
        </form>

        <!-- Contenu AJAX (Tableau + KPIs) -->
        <div id="transactions-container">
            {% include 'franchise/_transactions_list.html.twig' %}
        </div>
    </div>
</div>

{# SweetAlert2 CDN pour notifications AJAX #}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

{# Modal de confirmation de suppression #}
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content bg-dark border border-secondary text-white">
            <div class="modal-body text-center py-4">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-1 mb-3 d-block"></i>
                <h6 class="mb-2">Supprimer cette transaction ?</h6>
                <p class="text-muted small mb-0">Cette action est irréversible.</p>
            </div>
            <div class="modal-footer border-secondary justify-content-center py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-sm btn-danger" id="confirmDeleteBtn">Supprimer</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Hover : afficher l'icône de suppression */
    .tx-row:hover .delete-icon { opacity: 1 !important; }

    /* Cellule éditable */
    .editable-cell {
        cursor: pointer;
        position: relative;
        transition: background-color 0.2s ease;
        border-radius: 4px;
    }
    .editable-cell:hover { background-color: rgba(0, 229, 255, 0.08); }       
    .editable-cell:hover::after {
        content: '\F4CB';
        font-family: 'bootstrap-icons';
        position: absolute;
        right: 6px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.7rem;
        color: #00e5ff;
        opacity: 0.7;
    }

    /* Input inline */
    .editable-cell input {
        background: transparent;
        border: 1px solid #00e5ff;
        border-radius: 4px;
        color: #fff;
        padding: 2px 6px;
        width: 100%;
        outline: none;
        font-size: inherit;
    }

    .editable-cell .inline-error {
        position: absolute;
        bottom: -18px;
        left: 0;
        font-size: 0.7rem;
        color: #dc3545;
        white-space: nowrap;
        animation: fadeInError 0.3s ease;
    }
    @keyframes fadeInError {
        from { opacity: 0; transform: translateY(-4px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .tx-row.removing { animation: slideOutLeft 0.4s ease forwards; }
    @keyframes slideOutLeft {
        to { opacity: 0; transform: translateX(-30px); }
    }
    .editable-cell.success-flash { animation: successPulse 0.5s ease; }       
    @keyframes successPulse {
        0% { background-color: rgba(25, 135, 84, 0.3); }
        100% { background-color: transparent; }
    }
      
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {

    // ===== ÉTAT GLOBAL DES FILTRES =====
    let currentSort = '{{ currentSort|default("date") }}';
    let currentDirection = '{{ currentDirection|default("DESC") }}';
    const baseUrl = '{{ path("app_transaction_historique") }}';

    // ===== FONCTION CENTRALE : updateTable via Fetch API =====
    function updateTable() {
        const search = document.querySelector('input[name="search"]')?.value || '';
        const type = document.querySelector('select[name="type"]')?.value || 'TOUT';
        const periode = document.getElementById('periodeValue')?.value || 'this_month';
        const dateStart = document.getElementById('customDateStart')?.value || '';
        const dateEnd = document.getElementById('customDateEnd')?.value || '';

        const params = new URLSearchParams({
            search: search,
            type: type,
            periode: periode,
            date_start: dateStart,
            date_end: dateEnd,
            sort: currentSort,
            direction: currentDirection
        });

        // Mise à jour du lien d'export pour inclure les paramètres actuels
        const exportBtn = document.getElementById('btn-export-excel');
        if (exportBtn) {
            // Le chemin de base doit correspondre à #[Route('/historique/export')] dans TransactionController
            exportBtn.href = '/transaction/historique/export?' + params.toString();
        }

        fetch(baseUrl + '?' + params.toString(), {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            document.getElementById('transactions-container').innerHTML = html;
            // Ré-attacher les listeners dynamiques sur le nouveau contenu
            bindSortHeaders();
            bindEditableCells();
            bindDeleteIcons();
        })
        .catch(err => {
            console.error('Erreur AJAX updateTable:', err);
        });
    }

    // ===== DEBOUNCE (éviter trop de requêtes pendant la saisie) =====
    let debounceTimer = null;
    function debounce(fn, delay) {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(fn, delay);
    }

    // ===== EVENT : Recherche textuelle (input) =====
    const searchInput = document.querySelector('input[name="search"]');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            debounce(updateTable, 300);
        });
        searchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') e.preventDefault();
        });
    }

    // ===== EVENT : Select Type (change) =====
    const typeSelect = document.querySelector('select[name="type"]');
    if (typeSelect) {
        // Retirer le onchange="this.form.submit()" HTML qui causait le rechargement
        typeSelect.removeAttribute('onchange');
        typeSelect.addEventListener('change', function() {
            updateTable();
        });
    }

    // ===== EVENT : Filtre Période =====
    const periodeValue = document.getElementById('periodeValue');
    const periodLabel = document.getElementById('currentPeriodLabel');
    const periodOptions = document.querySelectorAll('.period-option');

    const labelsMap = {
        'this_month': 'Ce Mois',
        'last_month': 'Mois Dernier',
        'this_year': 'Cette Année',
        'all': 'Tout',
        'custom': 'Personnalisée'
    };

    // Initialiser le label
    if (periodeValue && periodLabel) {
        const initialVal = periodeValue.value || 'this_month';
        if (initialVal === 'custom') {
            const s = document.getElementById('customDateStart')?.value;
            const e = document.getElementById('customDateEnd')?.value;
            if (s || e) periodLabel.innerText = 'Du ' + (s || '...') + ' au ' + (e || '...');
            else periodLabel.innerText = 'Période : Personnalisée';
        } else {
            periodLabel.innerText = 'Période : ' + (labelsMap[initialVal] || 'Ce Mois');
        }
    }

    periodOptions.forEach(opt => {
        opt.addEventListener('click', function(e) {
            e.preventDefault();
            const val = this.getAttribute('data-value');
            periodeValue.value = val;
            document.getElementById('customDateStart').value = '';
            document.getElementById('customDateEnd').value = '';
            periodLabel.innerText = 'Période : ' + (labelsMap[val] || val);
            
            // Fermer le dropdown
            const dropdown = document.getElementById('periodeDropdown');
            if (dropdown) bootstrap.Dropdown.getOrCreateInstance(dropdown).hide();
            
            updateTable();
        });
    });

    // Bouton OK plage personnalisée
    const customBtn = document.querySelector('.custom-date-btn');
    if (customBtn) {
        customBtn.addEventListener('click', function(e) {
            e.preventDefault();
            periodeValue.value = 'custom';
            const s = document.getElementById('customDateStart').value;
            const en = document.getElementById('customDateEnd').value;
            periodLabel.innerText = 'Du ' + (s || '...') + ' au ' + (en || '...');
            
            const dropdown = document.getElementById('periodeDropdown');
            if (dropdown) bootstrap.Dropdown.getOrCreateInstance(dropdown).hide();
            
            updateTable();
        });
    }

    // Empêcher la fermeture du dropdown quand on clique sur les inputs date
    document.querySelectorAll('.custom-date-input, .dropdown-menu').forEach(el => {
        el.addEventListener('click', function(e) { e.stopPropagation(); });
    });

    // ===== BOUTON RÉINITIALISER =====
    const resetBtn = document.getElementById('resetFiltersBtn');
    if (resetBtn) {
        resetBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (searchInput) searchInput.value = '';
            if (typeSelect) typeSelect.value = 'TOUT';
            if (periodeValue) periodeValue.value = 'all';
            document.getElementById('customDateStart').value = '';
            document.getElementById('customDateEnd').value = '';
            if (periodLabel) periodLabel.innerText = 'Période : Tout';
            currentSort = 'date';
            currentDirection = 'DESC';
            updateTable();
        });
    }

    // ===== TRI PAR COLONNE (délégué au container) =====
    function bindSortHeaders() {
        document.querySelectorAll('.sort-header').forEach(header => {
            header.addEventListener('click', function(e) {
                e.preventDefault();
                const col = this.dataset.sort;
                if (currentSort === col) {
                    currentDirection = currentDirection === 'ASC' ? 'DESC' : 'ASC';
                } else {
                    currentSort = col;
                    currentDirection = 'ASC';
                }
                updateTable();
            });
        });
    }
    bindSortHeaders(); // Premier bind

    // ===== UTILITAIRES =====
    function showToast(message, type) {
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            background: '#1e293b',
            color: '#fff'
        });
        Toast.fire({ icon: type === 'error' ? 'error' : 'success', title: message });
    }

    function formatNumber(num) {
        return parseFloat(num).toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' TND';
    }

    // ===== ÉDITION INLINE (double-clic) — liaison dynamique =====
    function bindEditableCells() {
        document.querySelectorAll('.editable-cell').forEach(function(cell) {
            cell.addEventListener('dblclick', function() {
                if (cell.querySelector('input')) return;

                const field = cell.dataset.field;
                const oldValue = cell.dataset.value;
                const row = cell.closest('tr');
                const txId = row.dataset.id;
                const originalHTML = cell.innerHTML;

                const input = document.createElement('input');
                input.type = field === 'date' ? 'date' : 'text';
                input.value = oldValue;
                cell.innerHTML = '';
                cell.appendChild(input);
                input.focus();
                if (input.type === 'text') input.select();

                function saveEdit() {
                    const newValue = input.value.trim();
                    if (newValue === oldValue) { cancelEdit(); return; }
                    if (field === 'description' && newValue.length < 3) { cancelEdit(); showToast('Minimum 3 caractères.', 'error'); return; }
                    if (field === 'montant') {
                        const num = parseFloat(newValue.replace(',', '.'));
                        if (isNaN(num) || num <= 0) { cancelEdit(); showToast('Le montant doit être > 0.', 'error'); return; }
                    }

                    const payload = {};
                    payload[field] = field === 'montant' ? parseFloat(newValue.replace(',', '.')) : newValue;

                    fetch('/transaction/' + txId + '/edit', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                        body: JSON.stringify(payload)
                    }).then(r => r.json()).then(data => {
                        if (data.success) {
                            showToast('Modifié avec succès !', 'success');
                            setTimeout(() => updateTable(), 500);
                        } else {
                            cancelEdit();
                            showToast(data.message || 'Erreur', 'error');
                        }
                    }).catch(() => { cancelEdit(); showToast('Erreur réseau.', 'error'); });
                }

                function cancelEdit() { cell.innerHTML = originalHTML; }

                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') { e.preventDefault(); saveEdit(); }
                    if (e.key === 'Escape') { cancelEdit(); }
                });
                input.addEventListener('blur', function() {
                    setTimeout(function() { if (cell.querySelector('input')) saveEdit(); }, 150);
                });
            });
        });
    }
    bindEditableCells(); // Premier bind

    // ===== SUPPRESSION — liaison dynamique =====
    let deleteId = null;
    const deleteModalEl = document.getElementById('deleteModal');
    let deleteModal = null;
    if (deleteModalEl) {
        deleteModal = new bootstrap.Modal(deleteModalEl);
    }

    function bindDeleteIcons() {
        document.querySelectorAll('.delete-icon').forEach(function(icon) {
            icon.addEventListener('click', function() {
                deleteId = this.dataset.id;
                if (deleteModal) deleteModal.show();
            });
        });
    }
    bindDeleteIcons(); // Premier bind

    if (document.getElementById('confirmDeleteBtn')) {
        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (!deleteId) return;

            fetch('/transaction/' + deleteId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            }).then(r => {
                if (r.redirected || !r.headers.get('content-type')?.includes('application/json')) {
                    return { success: true };
                }
                return r.json();
            }).then(data => {
                if (deleteModal) deleteModal.hide();
                showToast('Transaction supprimée !', 'success');
                deleteId = null;
                setTimeout(() => updateTable(), 500);
            }).catch(() => {
                if (deleteModal) deleteModal.hide();
                showToast('Action effectuée.', 'success');
                deleteId = null;
                setTimeout(() => updateTable(), 500);
            });
        });
    }
});
</script>
{% endblock %}