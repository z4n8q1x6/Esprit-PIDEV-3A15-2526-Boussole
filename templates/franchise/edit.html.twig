{% extends 'front_base.html.twig' %}

{% block title %}Modifier Transaction{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 mb-0 text-white">Modifier la transaction</h1>
        <p class="text-muted">Ajustez les détails de votre transaction</p>
    </div>
</div>

<div class="card bg-dark border border-secondary shadow mb-4" style="background-color: #12141d !important; border-radius: 12px; max-width: 600px; margin: auto;">
    <div class="card-body p-4">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {{ form_widget(form) }}
            
            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_transaction_historique') }}" class="btn btn-outline-secondary rounded-pill px-4">Annuler</a>
                <button class="btn btn-primary rounded-pill fw-bold px-4" style="background-color: #0d6efd; border: none;">Enregistrer les modifications</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}