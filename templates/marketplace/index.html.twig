{% extends 'front_base.html.twig' %}

{% block title %}Marketplace{% endblock %}

{% block content %}
<div class="mb-4">
    <h2 class="fw-bold">Boutique & Marketplace</h2>
    <p class="text-muted">Découvrez nos produits disponibles pour votre entreprise.</p>
</div>



<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    {% for produit in produits %}
        <div class="col">
            <div class="card h-100 shadow-sm border-0 position-relative overflow-hidden product-card">
                <!-- Badge Promotion -->
                {% if produit.pourcentageReduction > 0 %}
                    <span class="badge bg-danger position-absolute top-0 start-0 m-2 z-index-9 fw-bold px-2 py-1 shadow-sm">
                        -{{ produit.pourcentageReduction }}%
                    </span>
                {% endif %}

                <!-- Badge Stock -->
                {% if produit.stockDispo < 5 %}
                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2 z-index-9">Stock faible</span>
                {% else %}
                    <span class="badge bg-success position-absolute top-0 end-0 m-2 z-index-9">En stock</span>
                {% endif %}

                <!-- Image -->
                <div class="product-img-wrapper" style="height: 200px; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center;">
                    {% if produit.image %}
                        <img src="{{ asset(produit.image) }}" class="card-img-top" alt="{{ produit.nom }}" style="max-height: 100%; width: auto; object-fit: contain; padding: 10px;">
                    {% else %}
                        <i class="bi bi-box-seam text-secondary" style="font-size: 4rem;"></i>
                    {% endif %}
                </div>

                <!-- Body -->
                <div class="card-body d-flex flex-column">
                    <p class="text-muted small mb-1">Réf: {{ produit.reference }}</p>
                    <h5 class="card-title fw-bold text-truncate" title="{{ produit.nom }}">{{ produit.nom }}</h5>
                    
                    <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                        <div class="d-flex flex-column">
                            {% if produit.pourcentageReduction > 0 %}
                                <del class="text-muted small lh-1 mb-1">{{ produit.prixAchat|number_format(2, ',', ' ') }} DT</del>
                                <span class="fs-5 fw-bold text-danger lh-1">{{ produit.prixApresReduction|number_format(2, ',', ' ') }} <small>DT</small></span>
                            {% else %}
                                <span class="fs-5 fw-bold text-primary lh-1 mt-1">{{ produit.prixAchat|number_format(2, ',', ' ') }} <small>DT</small></span>
                            {% endif %}
                        </div>
                        <a href="{{ path('app_panier_add', {'id': produit.id}) }}" class="btn btn-primary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Ajouter au panier">
                            <i class="bi bi-cart-plus fs-6"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12 text-center py-5 w-100">
            <i class="bi bi-shop text-muted" style="font-size: 5rem;"></i>
            <h4 class="mt-3 text-muted">Aucun produit disponible pour le moment.</h4>
        </div>
    {% endfor %}
</div>

<!-- Chatbot UI -->
<div id="chatbot-container" style="position: fixed; bottom: 20px; right: 20px; z-index: 1050; font-family: 'Inter', sans-serif;">
    <!-- Chat Button -->
    <button id="chatbot-toggle" class="btn rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; background: linear-gradient(135deg, #00e5ff 0%, #8a2be2 100%); border: none; transition: transform 0.3s;">
        <i class="bi bi-chat-dots fs-3 text-white"></i>
    </button>

    <!-- Chat Window -->
    <div id="chatbot-window" class="card shadow-lg d-none" style="position: absolute; bottom: 75px; right: 0; width: 350px; height: 450px; border-radius: 15px; overflow: hidden; border: 1px solid rgba(138, 43, 226, 0.2);">
        <!-- Header -->
        <div class="card-header text-white d-flex justify-content-between align-items-center p-3" style="background: linear-gradient(135deg, #8a2be2 0%, #00e5ff 100%);">
            <div class="d-flex align-items-center">
                <i class="bi bi-robot fs-4 me-2"></i>
                <h6 class="mb-0 fw-bold">Assistant Boussole</h6>
            </div>
            <button id="chatbot-close" class="btn-close btn-close-white" style="font-size: 0.8rem;"></button>
        </div>
        
        <!-- Messages Area -->
        <div id="chatbot-messages" class="card-body bg-light" style="overflow-y: auto; display: flex; flex-direction: column; gap: 10px;">
            <!-- Welcome message -->
            <div class="d-flex flex-row justify-content-start mb-2">
                <div class="p-3 bg-white border" style="border-radius: 15px 15px 15px 0px; max-width: 85%; font-size: 0.9rem;">
                    Bonjour ! 👋 Je suis l'assistant IA de la Marketplace. Comment puis-je vous aider aujourd'hui ?
                </div>
            </div>
        </div>
        
        <!-- Input Area -->
        <div class="card-footer bg-white p-2">
            <div class="input-group">
                <input type="text" id="chatbot-input" class="form-control" placeholder="Tapez votre message..." style="border-radius: 20px 0 0 20px; font-size: 0.9rem;" autocomplete="off">
                <button id="chatbot-send" class="btn btn-primary" style="border-radius: 0 20px 20px 0; background-color: #8a2be2; border-color: #8a2be2;">
                    <i class="bi bi-send-fill text-white"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
.product-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 229, 255, 0.15) !important;
}
.z-index-9 { z-index: 9; }

#chatbot-toggle:hover {
    transform: scale(1.1);
}
.chatbot-msg-user {
    background: linear-gradient(135deg, #00e5ff 0%, #00b4d8 100%);
    color: white;
    border-radius: 15px 15px 0px 15px;
    max-width: 85%;
    font-size: 0.9rem;
    padding: 10px 15px;
    align-self: flex-end;
}
.chatbot-msg-bot {
    background: white;
    color: #333;
    border: 1px solid #e0e0e0;
    border-radius: 15px 15px 15px 0px;
    max-width: 85%;
    font-size: 0.9rem;
    padding: 10px 15px;
    align-self: flex-start;
}
.typing-indicator span {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #8a2be2;
    border-radius: 50%;
    margin: 0 2px;
    animation: typing 1.4s infinite ease-in-out;
}
.typing-indicator span:nth-child(1) { animation-delay: 0s; }
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('chatbot-toggle');
    const closeBtn = document.getElementById('chatbot-close');
    const windowDiv = document.getElementById('chatbot-window');
    const messagesDiv = document.getElementById('chatbot-messages');
    const inputField = document.getElementById('chatbot-input');
    const sendBtn = document.getElementById('chatbot-send');

    // Toggle Chat Window
    toggleBtn.addEventListener('click', () => {
        windowDiv.classList.toggle('d-none');
        if (!windowDiv.classList.contains('d-none')) {
            inputField.focus();
        }
    });

    closeBtn.addEventListener('click', () => {
        windowDiv.classList.add('d-none');
    });

    // Send Message function
    const sendMessage = async () => {
        const text = inputField.value.trim();
        if (!text) return;

        // Add user message to UI
        addMessage(text, 'user');
        inputField.value = '';
        
        // Show typing indicator
        const typingId = showTypingIndicator();

        try {
            const response = await fetch('{{ path("app_chatbot_message") }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ message: text })
            });

            removeMessage(typingId);

            if (response.ok) {
                const data = await response.json();
                addMessage(data.response, 'bot');
            } else {
                addMessage("Erreur de connexion avec le serveur.", 'bot');
            }
        } catch (error) {
            removeMessage(typingId);
            addMessage("Une erreur est survenue.", 'bot');
        }
    };

    // Events
    sendBtn.addEventListener('click', sendMessage);
    inputField.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            sendMessage();
        }
    });

    // Helpers
    function addMessage(text, sender) {
        const wrapper = document.createElement('div');
        wrapper.className = `d-flex flex-row justify-content-${sender === 'user' ? 'end' : 'start'} mb-2`;
        
        const msgDiv = document.createElement('div');
        msgDiv.className = sender === 'user' ? 'chatbot-msg-user' : 'chatbot-msg-bot';
        msgDiv.innerHTML = text.replace(/\n/g, '<br>');
        
        wrapper.appendChild(msgDiv);
        messagesDiv.appendChild(wrapper);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function showTypingIndicator() {
        const id = 'typing-' + Date.now();
        const wrapper = document.createElement('div');
        wrapper.id = id;
        wrapper.className = `d-flex flex-row justify-content-start mb-2`;
        
        const msgDiv = document.createElement('div');
        msgDiv.className = 'chatbot-msg-bot typing-indicator';
        msgDiv.innerHTML = '<span></span><span></span><span></span>';
        
        wrapper.appendChild(msgDiv);
        messagesDiv.appendChild(wrapper);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        
        return id;
    }

    function removeMessage(id) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }
});
</script>

{% endblock %}
