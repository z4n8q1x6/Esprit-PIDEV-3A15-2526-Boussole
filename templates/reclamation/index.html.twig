{% extends 'front_base.html.twig' %}

{% block title %}Liste des Réclamations{% endblock %}

{% block content %}
<div class="page-content-wrapper">

    <div class="row mb-3">
        <div class="col-12 d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Liste des Réclamations</h1>
            <a href="{{ path('reclamation_new') }}" class="btn btn-sm btn-primary mb-0">
                <i class="bi bi-plus-lg me-2"></i>Nouvelle Réclamation
            </a>
        </div>
    </div>

    <div class="card bg-transparent border w-100">  {# ← w-100 on the card #}

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show m-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card-body p-0">
            <div class="mb-3 p-4 pb-0">
                <form method="get" class="d-flex gap-2">
                    <input
                            class="form-control form-control-sm"
                            placeholder="Rechercher par sujet..."
                            type="text"
                            name="q"
                            value="{{ app.request.query.get('q') }}"
                            >
                            <button type="submit" class="btn btn-primary btn-sm px-3">
                                Search
                            </button>
                    {% if app.request.query.get('q') is not empty %}
                    <a href="{{ path('reclamation_index') }}" class="btn btn-outline-secondary">
                        Clear
                    </a>
                    {% endif %}
                </form>
            </div>
            <div class="table-responsive">
                <table id="table-reclamation-user" class="table align-middle mb-0 table-hover" style="font-size: 0.95rem;">
                    <thead class="table-light">
                        {% set currentSort = app.request.query.get('sort', 'id') %}
                        {% set currentDir = app.request.query.get('direction', 'desc') %}
                        {% set query = app.request.query.get('q') %}
                        <tr>
                            <th scope="col" class="border-0 rounded-start ps-4 fw-600 text-uppercase letter-spacing" style="cursor: pointer;">
                                {% set isSujet = currentSort == 'sujet' %}
                                {% set nextDir = (isSujet and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('reclamation_index', {q: query, sort: 'sujet', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Sujet
                                    {% if isSujet %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>

                            <th scope="col" class="border-0 ps-3 fw-600 text-uppercase letter-spacing" style="cursor: pointer;">
                                {% set isDesc = currentSort == 'description' %}
                                {% set nextDir = (isDesc and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('reclamation_index', {q: query, sort: 'description', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Description
                                    {% if isDesc %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>

                            <th scope="col" class="border-0 ps-3 fw-600 text-uppercase letter-spacing text-center" style="cursor: pointer;">
                                {% set isStatut = currentSort == 'statut' %}
                                {% set nextDir = (isStatut and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('reclamation_index', {q: query, sort: 'statut', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Statut
                                    {% if isStatut %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>

                            <th scope="col" class="border-0 ps-3 fw-600 text-uppercase letter-spacing" style="cursor: pointer;">
                                {% set isDate = currentSort == 'date' %}
                                {% set nextDir = (isDate and currentDir == 'asc') ? 'desc' : 'asc' %}

                                <a href="{{ path('reclamation_index', {q: query, sort: 'date', direction: nextDir}) }}" class="text-reset text-decoration-none">
                                    Date
                                    {% if isDate %}<i class="bi {{ currentDir == 'asc' ? 'bi-arrow-up' : 'bi-arrow-down' }} ms-1"></i>{% endif %}
                                </a>
                            </th>

                            <th scope="col" class="border-0 rounded-end text-center ps-3 fw-600 text-uppercase letter-spacing">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for reclamation in reclamations %}
                            <tr class="border-bottom">
                                <td class="ps-4 py-3">
                                    <h6 class="mb-0 fw-500">
                                        <a href="#" class="text-primary-hover">{{ reclamation.sujet }}</a>
                                    </h6>
                                </td>

                                <td class="ps-3 py-3">
                                    <div style="max-width: 300px; word-break: break-word;">
                                        {% if reclamation.description|length > 80 %}{{ reclamation.description|slice(0, 80) }}...{% else %}{{ reclamation.description }}{% endif %}
                                    </div>
                                </td>

                                <td class="text-center ps-3 py-3">
                                    <span class="badge rounded-pill px-3 py-2
                                        {% if reclamation.statut == 'EN_ATTENTE' %} bg-warning text-dark
                                        {% elseif reclamation.statut == 'RESOLU' %} bg-success
                                        {% else %} bg-secondary
                                        {% endif %}">
                                        {{ reclamation.statut }}
                                    </span>
                                </td>

                                <td class="ps-3 py-3">
                                    <div class="small">
                                        <span class="fw-500 d-block">{{ reclamation.date_creation|date('d/m/Y') }}</span>
                                        <span class="text-muted" style="font-size: 0.8rem;">{{ reclamation.date_creation|date('H:i') }}</span>
                                    </div>
                                </td>

                                <td class="text-center ps-3 py-3">
                                    <button type="button" class="btn btn-sm btn-danger-soft delete-btn" data-bs-toggle="modal" data-bs-target="#deleteModal" data-delete-url="{{ path('reclamation_delete', {'id': reclamation.id}) }}" data-item-name="{{ reclamation.sujet }}" data-csrf-token="{{ csrf_token('delete-item') }}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4">Aucune réclamation trouvée.</td>
                            </tr>
                        {% endfor %}
                         </tbody>
                 </table>
             </div>
         </div>
     </div>
 </div>

 <!-- Modern Delete Confirmation Modal -->
 <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
     <div class="modal-dialog modal-dialog-centered">
         <div class="modal-content border-0 shadow-lg">
             <div class="modal-header bg-light border-bottom-0">
                 <h5 class="modal-title fw-600" id="deleteModalLabel">Confirmer la suppression</h5>
                 <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
             </div>
             <div class="modal-body text-center py-4">
                 <div class="mb-3">
                     <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                 </div>
                 <p class="text-muted mb-2">Êtes-vous sûr de vouloir supprimer ?</p>
                 <p class="fw-600 text-dark" id="deleteItemName"></p>
             </div>
             <div class="modal-footer bg-light border-top-0 gap-2">
                 <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                 <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Supprimer</button>
             </div>
         </div>
     </div>
 </div>

 <script>
 document.addEventListener('DOMContentLoaded', function() {
     const deleteModal = document.getElementById('deleteModal');
     const deleteButtons = document.querySelectorAll('.delete-btn');
     let currentDeleteUrl = null;
     let currentCsrfToken = null;

     deleteButtons.forEach(button => {
         button.addEventListener('click', function() {
             currentDeleteUrl = this.dataset.deleteUrl;
             currentCsrfToken = this.dataset.csrfToken;
             const itemName = this.dataset.itemName;
             document.getElementById('deleteItemName').textContent = itemName;
         });
     });

     document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
         if (currentDeleteUrl && currentCsrfToken) {
             const form = document.createElement('form');
             form.method = 'POST';
             form.action = currentDeleteUrl;
             
             const tokenInput = document.createElement('input');
             tokenInput.type = 'hidden';
             tokenInput.name = 'token';
             tokenInput.value = currentCsrfToken;
             
             form.appendChild(tokenInput);
             document.body.appendChild(form);
             form.submit();
         }
     });
 });
 </script>

 {% endblock %}
