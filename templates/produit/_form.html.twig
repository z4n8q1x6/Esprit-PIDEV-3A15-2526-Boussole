{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

<div class="row g-4">
    <div class="col-md-6">
        <div class="form-group">
            {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.nom) }}
            <div class="text-danger small mt-1 fw-bold">
                {{ form_errors(form.nom) }}
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="form-group">
            {{ form_label(form.reference, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.reference) }}
            <div class="text-danger small mt-1 fw-bold">
                {{ form_errors(form.reference) }}
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group">
            {{ form_label(form.prix_achat, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.prix_achat) }}
            <div class="text-danger small mt-1 fw-bold">
                {{ form_errors(form.prix_achat) }}
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group">
            {{ form_label(form.stock_dispo, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.stock_dispo) }}
            <div class="text-danger small mt-1 fw-bold">
                {{ form_errors(form.stock_dispo) }}
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="form-group">
            {{ form_label(form.pourcentage_reduction, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.pourcentage_reduction) }}
            <div class="text-danger small mt-1 fw-bold">
                {{ form_errors(form.pourcentage_reduction) }}
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="form-group">
            {{ form_label(form.image, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.image) }}
            <div class="text-danger small mt-1 fw-bold">
                {{ form_errors(form.image) }}
            </div>
            {% if produit.image %}
                <div class="mt-2">
                    <img src="{{ asset(produit.image) }}" alt="Image actuelle" style="max-height: 100px; border-radius: 8px; border: 2px solid #00e5ff;">
                    <small class="text-muted d-block mt-1">Image actuelle</small>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="d-flex justify-content-end mt-4 border-top pt-3">
    <a href="{{ path('app_produit') }}" class="btn btn-secondary me-2">Annuler</a>
    <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
</div>

{{ form_end(form) }}
