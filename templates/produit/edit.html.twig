{% extends 'back_base.html.twig' %}

{% block title %}Modifier le Produit{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12 mb-3">
        <h1 class="h3 mb-2">Modifier le Produit</h1>
        <p class="text-muted">Mise à jour des informations pour le produit: <strong class="text-primary">{{ produit.nom }}</strong></p>
    </div>
</div>

<div class="card shadow border-0">
    <div class="card-body p-4">
        {{ include('produit/_form.html.twig', {'button_label': 'Mettre à jour le Produit'}) }}
    </div>
</div>
{% endblock %}
